<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RayleaBot.Launcher.MainWindow"
        Title="{Binding Copy.WindowTitle}"
        Width="1440"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        SystemDecorations="BorderOnly"
        Background="#06101D"
        Foreground="#F4F8FF">
  <Window.Styles>
    <Style Selector="Border.glass-panel">
      <Setter Property="CornerRadius" Value="26" />
      <Setter Property="Padding" Value="24" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D9152A46" Offset="0" />
            <GradientStop Color="#BF0D1D34" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="BorderBrush" Value="#4A7FB74D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 18 42 0 #33000000" />
    </Style>

    <Style Selector="Border.info-panel">
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Background" Value="#C4142743" />
      <Setter Property="BorderBrush" Value="#334E7A4A" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.metric-chip">
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#A5182B46" />
      <Setter Property="BorderBrush" Value="#3B6EA266" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.page-heading">
      <Setter Property="FontSize" Value="30" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F8FBFF" />
    </Style>

    <Style Selector="TextBlock.panel-heading">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F5FAFF" />
    </Style>

    <Style Selector="TextBlock.section-caption">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#77E6FF" />
    </Style>

    <Style Selector="TextBlock.secondary">
      <Setter Property="Foreground" Value="#D3E1F3" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Foreground" Value="#F4F8FF" />
      <Setter Property="Background" Value="#96112139" />
      <Setter Property="BorderBrush" Value="#466D9D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="SelectionBrush" Value="#4CC7FF" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Foreground" Value="#031625" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#67E8FF" Offset="0" />
            <GradientStop Color="#28B9F0" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="BorderBrush" Value="#73EDFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="MinHeight" Value="46" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.primary:disabled">
      <Setter Property="Foreground" Value="#A8C4D8" />
      <Setter Property="Background" Value="#284661" />
      <Setter Property="BorderBrush" Value="#345F80" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.secondary">
      <Setter Property="Foreground" Value="#F4F8FF" />
      <Setter Property="Background" Value="#8F12243E" />
      <Setter Property="BorderBrush" Value="#4A74A7" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="MinHeight" Value="46" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="18,10" />
    </Style>

    <Style Selector="Button.secondary:disabled">
      <Setter Property="Foreground" Value="#93ABC2" />
      <Setter Property="Background" Value="#21344C" />
      <Setter Property="BorderBrush" Value="#314B68" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Foreground" Value="#D4E5FB" />
      <Setter Property="Background" Value="#5D10203A" />
      <Setter Property="BorderBrush" Value="#30507D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinHeight" Value="40" />
    </Style>

    <Style Selector="Button.ghost:disabled">
      <Setter Property="Foreground" Value="#879CB1" />
      <Setter Property="Background" Value="#1A283D" />
      <Setter Property="BorderBrush" Value="#294259" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.titlebar-button">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#5E0F1D33" />
      <Setter Property="Foreground" Value="#F3F8FF" />
      <Setter Property="BorderBrush" Value="#2E557D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.titlebar-button:pointerover">
      <Setter Property="Background" Value="#7B173256" />
      <Setter Property="BorderBrush" Value="#5F8FC7" />
    </Style>

    <Style Selector="Button.titlebar-close">
      <Setter Property="Background" Value="#7A2B1A27" />
      <Setter Property="BorderBrush" Value="#93505A" />
    </Style>

    <Style Selector="Button.titlebar-close:pointerover">
      <Setter Property="Background" Value="#9A3C2437" />
      <Setter Property="BorderBrush" Value="#C96A76" />
    </Style>

    <Style Selector="ListBox.side-nav">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox.side-nav ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">
    <Border Grid.RowSpan="2">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#06101D" Offset="0" />
          <GradientStop Color="#09162A" Offset="0.45" />
          <GradientStop Color="#081427" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <Border Grid.Row="0"
            Margin="18,18,18,12"
            Padding="14,10"
            Classes="glass-panel"
            PointerPressed="TitleBarPointerPressed"
            DoubleTapped="TitleBarDoubleTapped">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="16">
        <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
          <Border Width="38" Height="38" CornerRadius="19" Background="#60D6FF" BorderBrush="#A7F1FF" BorderThickness="1">
            <Border Width="18" Height="18" CornerRadius="9" Background="#0A1730" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding Copy.WindowTitle}" FontSize="18" FontWeight="SemiBold" Foreground="#F8FBFF" />
            <TextBlock Text="{Binding Copy.TitleBarHint}" Classes="secondary" FontSize="12" />
          </StackPanel>
        </StackPanel>

        <Border Grid.Column="1" Classes="metric-chip" HorizontalAlignment="Left" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding HeroAccentBrush}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" />
          </StackPanel>
        </Border>

        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   Text="{Binding OperationSummary}"
                   Foreground="#D5E4F8"
                   TextTrimming="CharacterEllipsis"
                   MaxWidth="420" />

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <Button Classes="titlebar-button" Click="MinimizeClicked">—</Button>
          <Button Classes="titlebar-button" Click="ToggleMaximizeClicked" Content="{Binding WindowStateGlyph}" />
          <Button Classes="titlebar-button titlebar-close" Click="CloseClicked">×</Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="18,0,18,18" ColumnDefinitions="250,*" ColumnSpacing="18">
      <Border Grid.Column="0" Classes="glass-panel" Padding="18">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding Copy.AppSubtitle}" FontSize="15" FontWeight="SemiBold" Foreground="#F7FBFF" />
            <TextBlock Text="主操作优先，诊断信息后置。" Classes="secondary" TextWrapping="Wrap" />
          </StackPanel>

          <ListBox Grid.Row="1"
                   Classes="side-nav"
                   ItemsSource="{Binding NavigationItems}"
                   SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border CornerRadius="18"
                        Padding="16,14"
                        Background="{Binding BackgroundBrush}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="1">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Title}" Foreground="{Binding TitleBrush}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Summary}" Foreground="{Binding SummaryBrush}" TextWrapping="Wrap" FontSize="13" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Border Grid.Row="2" Classes="info-panel" Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#F7FBFF" />
              <TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid Grid.Column="1">
        <ScrollViewer IsVisible="{Binding IsOverviewSectionActive}" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <Border Classes="glass-panel">
              <Grid ColumnDefinitions="1.35*,0.9*" ColumnSpacing="18">
                <StackPanel Spacing="12">
                  <TextBlock Classes="section-caption" Text="{Binding Copy.HeroEyebrow}" />
                  <TextBlock Classes="page-heading" Text="{Binding HeroTitle}" TextWrapping="Wrap" />
                  <Border Classes="metric-chip" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" />
                  </Border>
                  <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" Foreground="#D7E4F7" />
                </StackPanel>

                <Border Grid.Column="1" Classes="info-panel">
                  <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.EndpointLabel}" FontWeight="SemiBold" Foreground="#9EB3D1" />
                      <TextBlock Text="{Binding WebEndpoint}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding WebEndpoint}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.SessionLabel}" FontWeight="SemiBold" Foreground="#9EB3D1" />
                      <TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" Foreground="#9EB3D1" />
                      <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#9EB3D1" />
                      <TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </Grid>
            </Border>

            <Grid ColumnDefinitions="1.05*,0.95*" ColumnSpacing="18">
              <Border Grid.Column="0" Classes="glass-panel">
                <StackPanel Spacing="12">
                  <TextBlock Classes="panel-heading" Text="{Binding Copy.PrimaryIssueLabel}" />
                  <TextBlock Text="{Binding Copy.OverviewIntro}" Classes="secondary" TextWrapping="Wrap" />
                  <Border Classes="info-panel"
                          IsVisible="{Binding HasPrimaryIssue}"
                          BorderBrush="{Binding HeroAccentBrush}">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold" FontSize="18" />
                      <TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding PrimaryIssueDetail}" Classes="secondary" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding PrimaryIssueRemediation}" Foreground="#7BE0FF" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                  <Border Classes="info-panel"
                          IsVisible="{Binding HasLastError}"
                          BorderBrush="#AA6E7F">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding Copy.SecondaryIssueLabel}" FontWeight="SemiBold" FontSize="18" />
                      <TextBlock Text="{Binding LastError}" Foreground="#FFD0D6" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Classes="glass-panel">
                <StackPanel Spacing="14">
                  <TextBlock Classes="panel-heading" Text="{Binding Copy.ServiceControlsTitle}" />
                  <TextBlock Text="{Binding Copy.ControlsIntro}" Classes="secondary" TextWrapping="Wrap" />
                  <WrapPanel ItemHeight="46" ItemWidth="220">
                    <Button Classes="primary" Margin="0,0,12,12" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                    <Button Classes="secondary" Margin="0,0,12,12" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                    <Button Classes="secondary" Margin="0,0,12,12" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding Copy.OpenWebUiLabel}" />
                    <Button Classes="secondary" Margin="0,0,12,12" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                    <Button Classes="ghost" Margin="0,0,12,12" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                    <Button Classes="ghost" Margin="0,0,12,12" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                  </WrapPanel>
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer IsVisible="{Binding IsServiceControlsSectionActive}" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <Border Classes="glass-panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="page-heading" Text="{Binding Copy.ServiceControlsTitle}" />
                <TextBlock Text="{Binding Copy.ControlsIntro}" Classes="secondary" TextWrapping="Wrap" />
                <WrapPanel ItemHeight="46" ItemWidth="220">
                  <Button Classes="primary" Margin="0,0,12,12" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                  <Button Classes="secondary" Margin="0,0,12,12" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                  <Button Classes="secondary" Margin="0,0,12,12" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding Copy.OpenWebUiLabel}" />
                  <Button Classes="secondary" Margin="0,0,12,12" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                  <Button Classes="ghost" Margin="0,0,12,12" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                  <Button Classes="ghost" Margin="0,0,12,12" Click="OpenReleasePageClicked" IsEnabled="{Binding CanOpenReleasePage}" Content="{Binding Copy.OpenReleasePageLabel}" />
                  <Button Classes="ghost" Margin="0,0,12,12" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Grid ColumnDefinitions="1*,1*" ColumnSpacing="18">
              <Border Grid.Column="0" Classes="glass-panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="panel-heading" Text="{Binding Copy.StatusLabel}" />
                  <Border Classes="metric-chip" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" />
                  </Border>
                  <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SessionSummary}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Classes="glass-panel">
                <StackPanel Spacing="10">
                  <TextBlock Classes="panel-heading" Text="{Binding Copy.VersionLabel}" />
                  <TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer IsVisible="{Binding IsEnvironmentSectionActive}" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <Border Classes="glass-panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="page-heading" Text="{Binding Copy.EnvironmentTitle}" />
                <TextBlock Text="{Binding Copy.EnvironmentIntro}" Classes="secondary" TextWrapping="Wrap" />
                <WrapPanel>
                  <Border Classes="metric-chip">
                    <TextBlock Text="{Binding BlockingEnvironmentCheckCount, StringFormat=阻塞项 {0}}" Foreground="#FF8A97" FontWeight="SemiBold" />
                  </Border>
                  <Border Classes="metric-chip">
                    <TextBlock Text="{Binding WarningEnvironmentCheckCount, StringFormat=需注意 {0}}" Foreground="#FFC86E" FontWeight="SemiBold" />
                  </Border>
                  <Border Classes="metric-chip">
                    <TextBlock Text="{Binding ReadyEnvironmentCheckCount, StringFormat=正常 {0}}" Foreground="#5DE7A5" FontWeight="SemiBold" />
                  </Border>
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Classes="glass-panel">
              <StackPanel Spacing="16">
                <Expander IsExpanded="True">
                  <Expander.Header>
                    <TextBlock Text="{Binding Copy.BlockingGroupTitle}" FontSize="18" FontWeight="SemiBold" />
                  </Expander.Header>
                  <StackPanel Margin="0,12,0,0" Spacing="12">
                    <ItemsControl ItemsSource="{Binding BlockingEnvironmentChecks}" IsVisible="{Binding HasBlockingEnvironmentChecks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="info-panel" BorderBrush="{Binding AccentBrush}">
                            <StackPanel Spacing="8">
                              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="18" />
                                <Border Classes="metric-chip">
                                  <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" />
                                </Border>
                              </Grid>
                              <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoBlockingEnvironmentChecks}" />
                  </StackPanel>
                </Expander>

                <Expander IsExpanded="True">
                  <Expander.Header>
                    <TextBlock Text="{Binding Copy.WarningGroupTitle}" FontSize="18" FontWeight="SemiBold" />
                  </Expander.Header>
                  <StackPanel Margin="0,12,0,0" Spacing="12">
                    <ItemsControl ItemsSource="{Binding WarningEnvironmentChecks}" IsVisible="{Binding HasWarningEnvironmentChecks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="info-panel" BorderBrush="{Binding AccentBrush}">
                            <StackPanel Spacing="8">
                              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="18" />
                                <Border Classes="metric-chip">
                                  <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" />
                                </Border>
                              </Grid>
                              <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoWarningEnvironmentChecks}" />
                  </StackPanel>
                </Expander>

                <Expander>
                  <Expander.Header>
                    <TextBlock Text="{Binding Copy.ReadyGroupTitle}" FontSize="18" FontWeight="SemiBold" />
                  </Expander.Header>
                  <StackPanel Margin="0,12,0,0" Spacing="12">
                    <ItemsControl ItemsSource="{Binding ReadyEnvironmentChecks}" IsVisible="{Binding HasReadyEnvironmentChecks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="info-panel" BorderBrush="{Binding AccentBrush}">
                            <StackPanel Spacing="8">
                              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="18" />
                                <Border Classes="metric-chip">
                                  <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" />
                                </Border>
                              </Grid>
                              <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoReadyEnvironmentChecks}" />
                  </StackPanel>
                </Expander>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer IsVisible="{Binding IsSettingsSectionActive}" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <Border Classes="glass-panel">
              <StackPanel Spacing="14">
                <TextBlock Classes="page-heading" Text="{Binding Copy.SettingsTitle}" />
                <TextBlock Text="{Binding Copy.SettingsIntro}" Classes="secondary" TextWrapping="Wrap" />

                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding Copy.ServerExecutableLabel}" FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBox Grid.Column="0" Text="{Binding ServerExecutablePath, Mode=TwoWay}" Watermark="请输入服务端可执行文件路径" />
                    <Button Grid.Column="1" Classes="ghost" Click="CopyServerExecutableClicked" Content="{Binding Copy.CopyPathLabel}" />
                    <Button Grid.Column="2" Classes="ghost" Click="OpenServerExecutableDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding Copy.ConfigPathLabel}" FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBox Grid.Column="0" Text="{Binding ConfigPath, Mode=TwoWay}" Watermark="请输入用户配置文件路径" />
                    <Button Grid.Column="1" Classes="ghost" Click="CopyConfigPathClicked" Content="{Binding Copy.CopyPathLabel}" />
                    <Button Grid.Column="2" Classes="ghost" Click="OpenConfigDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding Copy.WorkdirLabel}" FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBox Grid.Column="0" Text="{Binding Workdir, Mode=TwoWay}" Watermark="请输入工作目录" />
                    <Button Grid.Column="1" Classes="ghost" Click="CopyWorkdirClicked" Content="{Binding Copy.CopyPathLabel}" />
                    <Button Grid.Column="2" Classes="ghost" Click="OpenWorkdirClicked" Content="{Binding Copy.OpenDirectoryLabel}" />
                  </Grid>
                </StackPanel>

                <CheckBox IsChecked="{Binding CloseToTrayEnabled, Mode=TwoWay}" Content="{Binding Copy.CloseToTrayEnabledLabel}" />

                <WrapPanel ItemHeight="46" ItemWidth="180">
                  <Button Classes="primary" Margin="0,0,12,0" Click="SaveSettingsClicked" Content="{Binding Copy.SaveSettingsLabel}" />
                </WrapPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <ScrollViewer IsVisible="{Binding IsDiagnosticsSectionActive}" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <Border Classes="glass-panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="page-heading" Text="{Binding Copy.DiagnosticsTitle}" />
                <TextBlock Text="{Binding Copy.DiagnosticsIntro}" Classes="secondary" TextWrapping="Wrap" />
                <WrapPanel ItemHeight="42" ItemWidth="180">
                  <Button Classes="secondary" Margin="0,0,12,12" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                  <Button Classes="secondary" Margin="0,0,12,12" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Classes="glass-panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="panel-heading" Text="{Binding Copy.RecentStderrTitle}" />
                <ItemsControl ItemsSource="{Binding RecentStderr}" IsVisible="{Binding HasRecentStderr}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,10"
                              Padding="14"
                              CornerRadius="16"
                              Background="#9A0E1C33"
                              BorderBrush="#2B456C"
                              BorderThickness="1">
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas,monospace" Foreground="#E9F3FF" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding Copy.RawDiagnosticsEmpty}" Classes="secondary" IsVisible="{Binding HasNoRecentStderr}" />
              </StackPanel>
            </Border>

            <Border Classes="glass-panel">
              <StackPanel Spacing="12">
                <TextBlock Classes="panel-heading" Text="{Binding Copy.DiagnosticsSummaryTitle}" />
                <TextBox Text="{Binding DiagnosticsSummary}"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MinHeight="260" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>
