<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RayleaBot.Launcher.MainWindow"
        Title="{Binding Copy.WindowTitle}"
        Width="1460"
        Height="940"
        MinWidth="1220"
        MinHeight="780"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        TransparencyLevelHint="None"
        Background="#08111E"
        Foreground="#F5F9FF">
  <Window.Resources>
    <ControlTheme x:Key="LauncherActionButtonTheme" TargetType="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border x:Name="PART_Border"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  MinHeight="{TemplateBinding MinHeight}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter x:Name="PART_ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True" />
          </Border>
        </ControlTemplate>
      </Setter>
    </ControlTheme>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Border.shell"><Setter Property="CornerRadius" Value="30" /><Setter Property="Padding" Value="0" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#101A2B" Offset="0" /><GradientStop Color="#0B1626" Offset="0.6" /><GradientStop Color="#08111F" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#294059" /><Setter Property="BorderThickness" Value="1" /><Setter Property="BoxShadow" Value="0 16 34 0 #20000000" /></Style>
    <Style Selector="Border.glass-panel"><Setter Property="CornerRadius" Value="22" /><Setter Property="Padding" Value="18" /><Setter Property="ClipToBounds" Value="True" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#15253A" Offset="0" /><GradientStop Color="#101B2F" Offset="0.56" /><GradientStop Color="#0B1524" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#28415C" /><Setter Property="BorderThickness" Value="1" /><Setter Property="BoxShadow" Value="0 8 22 0 #12000000" /></Style>
    <Style Selector="Border.subtle-panel"><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="16" /><Setter Property="Background" Value="#67132338" /><Setter Property="BorderBrush" Value="#29425F" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.hero-glass"><Setter Property="CornerRadius" Value="24" /><Setter Property="Padding" Value="28" /><Setter Property="ClipToBounds" Value="True" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#17304B" Offset="0" /><GradientStop Color="#101F34" Offset="0.58" /><GradientStop Color="#0A1523" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#2B4662" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.sidebar-item"><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="14,13" /><Setter Property="Background" Value="#4F122338" /><Setter Property="BorderBrush" Value="#243C54" /><Setter Property="BorderThickness" Value="1" /><Setter Property="ClipToBounds" Value="True" /></Style>
    <Style Selector="Border.metric-chip"><Setter Property="CornerRadius" Value="999" /><Setter Property="Padding" Value="12,6" /><Setter Property="Background" Value="#62142840" /><Setter Property="BorderBrush" Value="#49739D" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.environment-item"><Setter Property="CornerRadius" Value="12" /><Setter Property="Padding" Value="10,9" /><Setter Property="Background" Value="#65101F32" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.diagnostics-surface"><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="0" /><Setter Property="Background" Value="#9810192A" /><Setter Property="BorderBrush" Value="#355A80" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="TextBlock.page-heading"><Setter Property="FontSize" Value="40" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#FAFDFF" /></Style>
    <Style Selector="TextBlock.panel-heading"><Setter Property="FontSize" Value="24" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#F7FBFF" /></Style>
    <Style Selector="TextBlock.section-caption"><Setter Property="FontSize" Value="12" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#8FE8FF" /></Style>
    <Style Selector="TextBlock.secondary"><Setter Property="Foreground" Value="#E2EEFB" /><Setter Property="FontSize" Value="14" /></Style>
    <Style Selector="TextBlock.muted"><Setter Property="Foreground" Value="#C8D8EB" /><Setter Property="FontSize" Value="13" /></Style>
    <Style Selector="TextBox"><Setter Property="Foreground" Value="#F7FBFF" /><Setter Property="Background" Value="#AA122238" /><Setter Property="BorderBrush" Value="#4874A7" /><Setter Property="BorderThickness" Value="1" /><Setter Property="SelectionBrush" Value="#6BDFFF" /><Setter Property="CornerRadius" Value="16" /><Setter Property="Padding" Value="14,11" /></Style>
    <Style Selector="Button.primary"><Setter Property="Theme" Value="{StaticResource LauncherActionButtonTheme}" /><Setter Property="Foreground" Value="#04131F" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#A7F6FF" Offset="0" /><GradientStop Color="#51CDEF" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#D4FBFF" /><Setter Property="BorderThickness" Value="1" /><Setter Property="MinHeight" Value="48" /><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="18,10" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
    <Style Selector="Button.primary:pointerover"><Setter Property="Foreground" Value="#04111B" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#C0FAFF" Offset="0" /><GradientStop Color="#60DAFF" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#E0FDFF" /></Style>
    <Style Selector="Button.primary:pressed"><Setter Property="Foreground" Value="#03101A" /><Setter Property="Background" Value="#46BFE3" /><Setter Property="BorderBrush" Value="#96EEFF" /></Style>
    <Style Selector="Button.primary:disabled"><Setter Property="Foreground" Value="#99BFE2" /><Setter Property="Background" Value="#173047" /><Setter Property="BorderBrush" Value="#4F759A" /><Setter Property="Opacity" Value="1" /></Style>
    <Style Selector="Button.secondary"><Setter Property="Theme" Value="{StaticResource LauncherActionButtonTheme}" /><Setter Property="Foreground" Value="#FDFEFF" /><Setter Property="Background" Value="#88162A43" /><Setter Property="BorderBrush" Value="#6D9FD2" /><Setter Property="BorderThickness" Value="1" /><Setter Property="MinHeight" Value="48" /><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="18,10" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
    <Style Selector="Button.secondary:pointerover"><Setter Property="Foreground" Value="#FFFFFF" /><Setter Property="Background" Value="#A51E3960" /><Setter Property="BorderBrush" Value="#9ED3FF" /></Style>
    <Style Selector="Button.secondary:pressed"><Setter Property="Foreground" Value="#FFFFFF" /><Setter Property="Background" Value="#7E23425F" /><Setter Property="BorderBrush" Value="#7CB5E6" /></Style>
    <Style Selector="Button.secondary:disabled"><Setter Property="Foreground" Value="#96BADB" /><Setter Property="Background" Value="#182B40" /><Setter Property="BorderBrush" Value="#476C8F" /><Setter Property="Opacity" Value="1" /></Style>
    <Style Selector="Button.ghost"><Setter Property="Theme" Value="{StaticResource LauncherActionButtonTheme}" /><Setter Property="Foreground" Value="#F7FBFF" /><Setter Property="Background" Value="#6014273F" /><Setter Property="BorderBrush" Value="#507CA8" /><Setter Property="BorderThickness" Value="1" /><Setter Property="CornerRadius" Value="16" /><Setter Property="Padding" Value="14,9" /><Setter Property="MinHeight" Value="42" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
    <Style Selector="Button.ghost:pointerover"><Setter Property="Foreground" Value="#FFFFFF" /><Setter Property="Background" Value="#7F1C3250" /><Setter Property="BorderBrush" Value="#86BDEF" /></Style>
    <Style Selector="Button.ghost:pressed"><Setter Property="Foreground" Value="#F9FCFF" /><Setter Property="Background" Value="#5614263E" /><Setter Property="BorderBrush" Value="#688FB8" /></Style>
    <Style Selector="Button.ghost:disabled"><Setter Property="Foreground" Value="#8EAED0" /><Setter Property="Background" Value="#142537" /><Setter Property="BorderBrush" Value="#3F627F" /><Setter Property="Opacity" Value="1" /></Style>
    <Style Selector="Button.window-button"><Setter Property="Theme" Value="{StaticResource LauncherActionButtonTheme}" /><Setter Property="Width" Value="36" /><Setter Property="Height" Value="36" /><Setter Property="Padding" Value="0" /><Setter Property="Background" Value="#10253A" /><Setter Property="Foreground" Value="#F7FBFF" /><Setter Property="BorderBrush" Value="#355572" /><Setter Property="BorderThickness" Value="1" /><Setter Property="CornerRadius" Value="11" /></Style>
    <Style Selector="Button.window-button:pointerover"><Setter Property="Background" Value="#1B3854" /><Setter Property="BorderBrush" Value="#7EBEFF" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="Button.window-button:pressed"><Setter Property="Background" Value="#102538" /><Setter Property="BorderBrush" Value="#5B8CB9" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="Button.window-close"><Setter Property="Foreground" Value="#FFF7F8" /></Style>
    <Style Selector="Button.window-close:pointerover"><Setter Property="Background" Value="#4B2030" /><Setter Property="BorderBrush" Value="#E18694" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="Button.window-close:pressed"><Setter Property="Background" Value="#5D2332" /><Setter Property="BorderBrush" Value="#EEA0AC" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="Button.nav-button"><Setter Property="Background" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="0,0,0,12" /><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="HorizontalAlignment" Value="Stretch" /><Setter Property="Focusable" Value="False" /></Style>
    <Style Selector="Button.nav-button:pointerover"><Setter Property="Background" Value="Transparent" /></Style>
    <Style Selector="Button.nav-button:pressed"><Setter Property="Background" Value="Transparent" /></Style>
  </Window.Styles>
  <Grid Background="#08111E" ClipToBounds="True">
    <Border Classes="shell" Margin="4" ClipToBounds="True">
      <Grid Margin="12">
      <Grid IsHitTestVisible="False">
        <Border Width="420" Height="420" CornerRadius="210" Background="#1F5A98" Opacity="0.17" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-140,-170,0,0" />
        <Border Width="520" Height="520" CornerRadius="260" Background="#0DA7E9" Opacity="0.08" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-190,-150,0" />
        <Border Width="360" Height="360" CornerRadius="180" Background="#265FF0" Opacity="0.07" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,260,-120" />
      </Grid>
      <Grid RowDefinitions="Auto,*" RowSpacing="18">
        <Border Grid.Row="0" Classes="glass-panel" Padding="18,16" PointerPressed="TitleBarPointerPressed" DoubleTapped="TitleBarDoubleTapped">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="16">
            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
              <Border Width="44" Height="44" CornerRadius="22" Background="#72D9FF" BorderBrush="#BDF4FF" BorderThickness="1"><Border Width="20" Height="20" CornerRadius="10" Background="#09172C" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding Copy.WindowTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#FBFDFF" />
                <TextBlock Text="{Binding Copy.TitleBarHint}" Classes="muted" />
                <TextBlock Text="{Binding OperationSummary}" Foreground="#E7F1FC" TextTrimming="CharacterEllipsis" MaxWidth="620" />
              </StackPanel>
            </StackPanel>
            <Border Grid.Column="1" Classes="metric-chip" HorizontalAlignment="Left" VerticalAlignment="Center"><StackPanel Orientation="Horizontal" Spacing="10"><Border Width="10" Height="10" CornerRadius="5" Background="{Binding HeroAccentBrush}" VerticalAlignment="Center" /><TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" /></StackPanel></Border>
            <Button Grid.Column="2" Classes="secondary" Click="OpenWebClicked" Content="{Binding OpenWebUiActionLabel}" IsEnabled="{Binding CanOpenWebUi}" MinWidth="176" VerticalAlignment="Center" />
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Classes="window-button" Click="MinimizeClicked">
                <Grid Width="14" Height="14">
                  <Border Width="12" Height="1.6" Background="#F6FBFF" CornerRadius="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
              </Button>
              <Button Classes="window-button" Click="ToggleMaximizeClicked" IsVisible="{Binding IsWindowNormal}">
                <Grid Width="14" Height="14">
                  <Border Width="11" Height="11" BorderBrush="#F6FBFF" BorderThickness="1.4" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
              </Button>
              <Button Classes="window-button" Click="ToggleMaximizeClicked" IsVisible="{Binding IsWindowMaximized}">
                <Grid Width="14" Height="14">
                  <Border Width="8.5" Height="8.5" BorderBrush="#F6FBFF" BorderThickness="1.4" CornerRadius="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="3,3,0,0" />
                  <Border Width="8.5" Height="8.5" BorderBrush="#F6FBFF" BorderThickness="1.4" CornerRadius="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,3,3" />
                </Grid>
              </Button>
              <Button Classes="window-button window-close" Click="CloseClicked">
                <Grid Width="14" Height="14">
                  <Border Width="12" Height="1.6" Background="#FFF8FA" CornerRadius="1" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                      <RotateTransform Angle="45" />
                    </Border.RenderTransform>
                  </Border>
                  <Border Width="12" Height="1.6" Background="#FFF8FA" CornerRadius="1" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                      <RotateTransform Angle="-45" />
                    </Border.RenderTransform>
                  </Border>
                </Grid>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
        <Grid Grid.Row="1" ColumnDefinitions="236,*" ColumnSpacing="18">
          <Border Grid.Column="0" Classes="glass-panel" Padding="18">
            <Grid RowDefinitions="Auto,*" RowSpacing="18">
              <TextBlock Text="{Binding Copy.SidebarTitle}" FontSize="17" FontWeight="SemiBold" Foreground="#F7FBFF" />
              <ItemsControl Grid.Row="1" ItemsSource="{Binding NavigationItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="nav-button" Tag="{Binding Section}" Click="NavigationItemClicked">
                      <Border Classes="sidebar-item" Background="{Binding BackgroundBrush}" BorderBrush="{Binding BorderBrush}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                          <Border Width="22" Height="22" CornerRadius="11" Background="#12263D" BorderBrush="{Binding BorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                            <Border Width="8" Height="8" CornerRadius="4" Background="{Binding BorderBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                          <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="{Binding TitleBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>
          <Grid Grid.Column="1">
            <ScrollViewer IsVisible="{Binding IsOverviewSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <Border Classes="hero-glass">
                <StackPanel Spacing="22">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="section-caption" Text="{Binding Copy.HeroEyebrow}" />
                      <TextBlock Classes="page-heading" Text="{Binding HeroTitle}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" Foreground="#E5EEF9" FontSize="18" MaxWidth="960" />
                    </StackPanel>
                    <Border Grid.Column="1" Classes="metric-chip" HorizontalAlignment="Right" VerticalAlignment="Top"><TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" /></Border>
                  </Grid>

                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18" RowDefinitions="Auto,Auto" RowSpacing="10">
                    <TextBlock Text="{Binding Copy.EndpointLabel}" FontWeight="SemiBold" Foreground="#AFC7E3" />
                    <TextBlock Grid.Column="1" Text="{Binding WebEndpoint}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding WebEndpoint}" />
                    <TextBlock Grid.Row="1" Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#AFC7E3" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                      <TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>

                  <Border Height="1" Background="#22394F" />

                  <StackPanel Spacing="14">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.MainActionsTitle}" />
                    <WrapPanel ItemWidth="198" ItemHeight="56" Orientation="Horizontal">
                      <Button Classes="primary" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding OpenWebUiActionLabel}" />
                      <Button Classes="secondary" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                      <Button Classes="secondary" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                      <Button Classes="ghost" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                      <Button Classes="ghost" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                      <Button Classes="ghost" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                    </WrapPanel>
                  </StackPanel>

                  <Border Height="1" Background="#22394F" />

                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.PrimaryIssueLabel}" />
                    <Border Classes="subtle-panel" IsVisible="{Binding HasPrimaryIssue}" BorderBrush="{Binding HeroAccentBrush}">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold" FontSize="20" />
                        <TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PrimaryIssueDetail}" Classes="secondary" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PrimaryIssueRemediation}" Foreground="{Binding HeroAccentBrush}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                    <Border Classes="subtle-panel" IsVisible="{Binding HasNoPrimaryIssue}" BorderBrush="#335C84">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold" FontSize="20" />
                        <TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PrimaryIssueDetail}" Classes="secondary" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>

                  <Border Height="1" Background="#22394F" />

                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.SecondaryIssueLabel}" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="18" RowSpacing="12">
                      <TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" Foreground="#AFC7E3" />
                      <TextBlock Grid.Column="1" Text="{Binding OperationSummary}" TextWrapping="Wrap" />
                      <TextBlock Grid.Row="1" Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#AFC7E3" />
                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VersionSummary}" TextWrapping="Wrap" />
                      <TextBlock Grid.Row="2" Text="{Binding Copy.DiagnosticsTitle}" FontWeight="SemiBold" Foreground="#AFC7E3" />
                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastError}" Foreground="#FFE2E6" TextWrapping="Wrap" IsVisible="{Binding HasLastError}" />
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </Border>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsServiceControlsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                    <StackPanel Spacing="12">
                      <TextBlock Classes="page-heading" Text="{Binding Copy.ServiceControlsTitle}" />
                      <TextBlock Text="{Binding ServiceDetail}" Classes="secondary" TextWrapping="Wrap" />
                      <Border Classes="metric-chip" HorizontalAlignment="Left"><TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" /></Border>
                      <Button Classes="primary" Click="OpenWebClicked" Content="{Binding OpenWebUiActionLabel}" IsEnabled="{Binding CanOpenWebUi}" HorizontalAlignment="Left" MinWidth="168" />
                    </StackPanel>
                    <Border Grid.Column="1" Classes="subtle-panel"><StackPanel Spacing="10"><TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" /><TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" /><TextBlock Text="{Binding Copy.EndpointLabel}" FontWeight="SemiBold" Margin="0,10,0,0" /><TextBlock Text="{Binding WebEndpoint}" TextWrapping="Wrap" /></StackPanel></Border>
                  </Grid>
                </Border>
                <Border Classes="glass-panel">
                  <WrapPanel ItemWidth="196" ItemHeight="56" Orientation="Horizontal">
                    <Button Classes="primary" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                    <Button Classes="secondary" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                    <Button Classes="secondary" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding OpenWebUiActionLabel}" />
                    <Button Classes="secondary" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                    <Button Classes="ghost" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                    <Button Classes="ghost" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                  </WrapPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsEnvironmentSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="page-heading" Text="{Binding Copy.EnvironmentTitle}" />
                    <TextBlock Text="{Binding Copy.EnvironmentIntro}" Classes="secondary" TextWrapping="Wrap" />
                    <WrapPanel>
                      <Border Classes="metric-chip"><TextBlock Text="{Binding BlockingEnvironmentCheckCount, StringFormat=阻塞项 {0}}" Foreground="#FF8C99" FontWeight="SemiBold" /></Border>
                      <Border Classes="metric-chip"><TextBlock Text="{Binding WarningEnvironmentCheckCount, StringFormat=需注意 {0}}" Foreground="#FFC86E" FontWeight="SemiBold" /></Border>
                      <Border Classes="metric-chip"><TextBlock Text="{Binding ReadyEnvironmentCheckCount, StringFormat=正常 {0}}" Foreground="#63E7A8" FontWeight="SemiBold" /></Border>
                    </WrapPanel>
                  </StackPanel>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="14">
                    <StackPanel Spacing="12">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Classes="panel-heading" Text="{Binding Copy.BlockingGroupTitle}" />
                        <Border Grid.Column="1" Classes="metric-chip"><TextBlock Text="{Binding BlockingEnvironmentCheckCount}" Foreground="#FF8C99" FontWeight="SemiBold" /></Border>
                      </Grid>
                      <ItemsControl ItemsSource="{Binding BlockingEnvironmentChecks}" IsVisible="{Binding HasBlockingEnvironmentChecks}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Classes="environment-item" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" />
                                <Border Grid.Column="1" Classes="metric-chip" Padding="10,4"><TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" /></Border>
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoBlockingEnvironmentChecks}" />
                    </StackPanel>
                    <StackPanel Spacing="12">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Classes="panel-heading" Text="{Binding Copy.WarningGroupTitle}" />
                        <Border Grid.Column="1" Classes="metric-chip"><TextBlock Text="{Binding WarningEnvironmentCheckCount}" Foreground="#FFC86E" FontWeight="SemiBold" /></Border>
                      </Grid>
                      <ItemsControl ItemsSource="{Binding WarningEnvironmentChecks}" IsVisible="{Binding HasWarningEnvironmentChecks}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Classes="environment-item" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" />
                                <Border Grid.Column="1" Classes="metric-chip" Padding="10,4"><TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" /></Border>
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoWarningEnvironmentChecks}" />
                    </StackPanel>
                    <StackPanel Spacing="12">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Classes="panel-heading" Text="{Binding Copy.ReadyGroupTitle}" />
                        <Border Grid.Column="1" Classes="metric-chip"><TextBlock Text="{Binding ReadyEnvironmentCheckCount}" Foreground="#63E7A8" FontWeight="SemiBold" /></Border>
                      </Grid>
                      <ItemsControl ItemsSource="{Binding ReadyEnvironmentChecks}" IsVisible="{Binding HasReadyEnvironmentChecks}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Classes="environment-item" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" />
                                <Border Grid.Column="1" Classes="metric-chip" Padding="10,4"><TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" /></Border>
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoReadyEnvironmentChecks}" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsSettingsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <StackPanel Spacing="16">
                    <TextBlock Classes="page-heading" Text="{Binding Copy.SettingsTitle}" />
                    <TextBlock Text="{Binding Copy.SettingsIntro}" Classes="secondary" TextWrapping="Wrap" />
                    <StackPanel Spacing="14">
                      <TextBlock Text="{Binding Copy.ServerExecutableLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding ServerExecutablePath, Mode=TwoWay}" Watermark="请输入服务端可执行文件路径" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyServerExecutableClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenServerExecutableDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                      </Grid>
                      <TextBlock Text="{Binding Copy.ConfigPathLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding ConfigPath, Mode=TwoWay}" Watermark="请输入用户配置文件路径" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyConfigPathClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenConfigDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                      </Grid>
                      <TextBlock Text="{Binding Copy.WorkdirLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding Workdir, Mode=TwoWay}" Watermark="请输入工作目录" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyWorkdirClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenWorkdirClicked" Content="{Binding Copy.OpenDirectoryLabel}" />
                      </Grid>
                      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="0,4,0,0">
                        <Button Grid.Column="0" Classes="primary" Width="148" Click="SaveSettingsClicked" Content="{Binding Copy.SaveSettingsLabel}" />
                        <TextBlock Grid.Column="1" Text="关闭窗口时会询问是隐藏到托盘还是完全退出。" Classes="secondary" VerticalAlignment="Center" TextWrapping="Wrap" />
                      </Grid>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsDiagnosticsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                    <StackPanel Spacing="12">
                      <TextBlock Classes="page-heading" Text="{Binding Copy.DiagnosticsTitle}" />
                      <TextBlock Text="{Binding Copy.DiagnosticsIntro}" Classes="secondary" TextWrapping="Wrap" />
                      <WrapPanel>
                        <Button Classes="secondary" Margin="0,0,12,12" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                        <Button Classes="secondary" Margin="0,0,12,12" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                      </WrapPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Classes="subtle-panel"><StackPanel Spacing="8"><TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" /><TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" /></StackPanel></Border>
                  </Grid>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.RecentStderrTitle}" />
                    <ItemsControl ItemsSource="{Binding RecentStderr}" IsVisible="{Binding HasRecentStderr}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10" Padding="14" CornerRadius="16" Background="#93111F36" BorderBrush="#35587F" BorderThickness="1">
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas,monospace" Foreground="#F5FAFF" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.RawDiagnosticsEmpty}" Classes="secondary" IsVisible="{Binding HasNoRecentStderr}" />
                  </StackPanel>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.DiagnosticsSummaryTitle}" />
                    <Border Classes="diagnostics-surface" MinHeight="260">
                      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding DiagnosticsSummary}" TextWrapping="Wrap" Padding="16" FontFamily="Cascadia Mono,Consolas,monospace" Foreground="#F5FAFF" />
                      </ScrollViewer>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
