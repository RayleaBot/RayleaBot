<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RayleaBot.Launcher.MainWindow"
        Title="{Binding Copy.WindowTitle}"
        Width="1460"
        Height="940"
        MinWidth="1220"
        MinHeight="780"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="Transparent"
        Foreground="#F5F9FF">
  <Window.Styles>
    <Style Selector="Border.shell">
      <Setter Property="CornerRadius" Value="32" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F20A1830" Offset="0" />
            <GradientStop Color="#EC0A1730" Offset="0.48" />
            <GradientStop Color="#E6081528" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="BorderBrush" Value="#284A6D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 32 64 0 #77000000" />
    </Style>

    <Style Selector="Border.glass-panel">
      <Setter Property="CornerRadius" Value="28" />
      <Setter Property="Padding" Value="22" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D5192E49" Offset="0" />
            <GradientStop Color="#CD112239" Offset="0.56" />
            <GradientStop Color="#C30D1A2E" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="BorderBrush" Value="#355D88" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 22 44 0 #30000000" />
    </Style>

    <Style Selector="Border.subtle-panel">
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="Background" Value="#97152742" />
      <Setter Property="BorderBrush" Value="#2E4E73" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.sidebar-item">
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="18,16" />
      <Setter Property="Background" Value="#9B12243E" />
      <Setter Property="BorderBrush" Value="#274567" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.metric-chip">
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#941B304B" />
      <Setter Property="BorderBrush" Value="#3E648F" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBlock.page-heading">
      <Setter Property="FontSize" Value="34" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F9FCFF" />
    </Style>

    <Style Selector="TextBlock.panel-heading">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F7FBFF" />
    </Style>

    <Style Selector="TextBlock.section-caption">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#8EE6FF" />
    </Style>

    <Style Selector="TextBlock.secondary">
      <Setter Property="Foreground" Value="#D6E3F6" />
      <Setter Property="FontSize" Value="14" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#AFC4DF" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Foreground" Value="#F6FAFF" />
      <Setter Property="Background" Value="#A712223A" />
      <Setter Property="BorderBrush" Value="#4470A3" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="SelectionBrush" Value="#5AD4FF" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="14,11" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Foreground" Value="#082238" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8BEFFF" Offset="0" />
            <GradientStop Color="#36BFEA" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="BorderBrush" Value="#A6F7FF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="MinHeight" Value="48" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.primary:disabled">
      <Setter Property="Foreground" Value="#8DA8C3" />
      <Setter Property="Background" Value="#223C58" />
      <Setter Property="BorderBrush" Value="#2A506E" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.secondary">
      <Setter Property="Foreground" Value="#F4F8FF" />
      <Setter Property="Background" Value="#99132646" />
      <Setter Property="BorderBrush" Value="#4F7AAD" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="MinHeight" Value="48" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="18,10" />
    </Style>

    <Style Selector="Button.secondary:disabled">
      <Setter Property="Foreground" Value="#8FA7BE" />
      <Setter Property="Background" Value="#1D324A" />
      <Setter Property="BorderBrush" Value="#27455F" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Foreground" Value="#E8F4FF" />
      <Setter Property="Background" Value="#6A11233E" />
      <Setter Property="BorderBrush" Value="#3A628B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="MinHeight" Value="42" />
    </Style>

    <Style Selector="Button.ghost:disabled">
      <Setter Property="Foreground" Value="#889FB7" />
      <Setter Property="Background" Value="#172A40" />
      <Setter Property="BorderBrush" Value="#233C54" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.titlebar-button">
      <Setter Property="Width" Value="48" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#64122540" />
      <Setter Property="Foreground" Value="#F5FAFF" />
      <Setter Property="BorderBrush" Value="#3B6694" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.titlebar-button:pointerover">
      <Setter Property="Background" Value="#83182E50" />
      <Setter Property="BorderBrush" Value="#69A2DA" />
    </Style>

    <Style Selector="Button.titlebar-close">
      <Setter Property="Background" Value="#7F2A253D" />
      <Setter Property="BorderBrush" Value="#A15B6B" />
    </Style>

    <Style Selector="Button.titlebar-close:pointerover">
      <Setter Property="Background" Value="#A7383450" />
      <Setter Property="BorderBrush" Value="#D57E89" />
    </Style>

    <Style Selector="ListBox.side-nav">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBox.side-nav ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </Window.Styles>

  <Grid Margin="10">
    <Border Classes="shell" />

    <Grid IsHitTestVisible="False">
      <Border Width="420"
              Height="420"
              CornerRadius="210"
              Background="#1E5FA1"
              Opacity="0.18"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="-90,-130,0,0" />
      <Border Width="520"
              Height="520"
              CornerRadius="260"
              Background="#0E9ED9"
              Opacity="0.10"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,-160,-150,0" />
      <Border Width="360"
              Height="360"
              CornerRadius="180"
              Background="#1C5EFF"
              Opacity="0.07"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,280,-120" />
    </Grid>

    <Grid RowDefinitions="Auto,*" Margin="18">
      <Border Grid.Row="0"
              Classes="glass-panel"
              Padding="16,14"
              PointerPressed="TitleBarPointerPressed"
              DoubleTapped="TitleBarDoubleTapped">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="16">
          <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
            <Border Width="44" Height="44" CornerRadius="22" Background="#70D8FF" BorderBrush="#B3F1FF" BorderThickness="1">
              <Border Width="20" Height="20" CornerRadius="10" Background="#09172C" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding Copy.WindowTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#FAFDFF" />
              <TextBlock Text="{Binding Copy.TitleBarHint}" Classes="secondary" />
            </StackPanel>
          </StackPanel>

          <Border Grid.Column="1" Classes="metric-chip" HorizontalAlignment="Left" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Border Width="10" Height="10" CornerRadius="5" Background="{Binding HeroAccentBrush}" VerticalAlignment="Center" />
              <TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" />
            </StackPanel>
          </Border>

          <TextBlock Grid.Column="2"
                     VerticalAlignment="Center"
                     Text="{Binding OperationSummary}"
                     Foreground="#D7E6F8"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="420" />

          <Border Grid.Column="3" Classes="subtle-panel" Padding="12,9" VerticalAlignment="Center">
            <TextBlock Text="{Binding ServiceDetail}" MaxWidth="320" TextTrimming="CharacterEllipsis" Foreground="#EDF5FF" />
          </Border>

          <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Classes="titlebar-button" Click="MinimizeClicked">—</Button>
            <Button Classes="titlebar-button" Click="ToggleMaximizeClicked" Content="{Binding WindowStateGlyph}" />
            <Button Classes="titlebar-button titlebar-close" Click="CloseClicked">×</Button>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="0,18,0,0" ColumnDefinitions="290,*" ColumnSpacing="18">
        <Border Grid.Column="0" Classes="glass-panel" Padding="20">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding Copy.SidebarTitle}" FontSize="17" FontWeight="SemiBold" Foreground="#F7FBFF" />
              <TextBlock Text="{Binding Copy.SidebarSummary}" Classes="secondary" TextWrapping="Wrap" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     Classes="side-nav"
                     ItemsSource="{Binding NavigationItems}"
                     SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="sidebar-item"
                          Background="{Binding BackgroundBrush}"
                          BorderBrush="{Binding BorderBrush}">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding Title}" Foreground="{Binding TitleBrush}" FontSize="18" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Summary}" Foreground="{Binding SummaryBrush}" TextWrapping="Wrap" FontSize="13" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="2" Classes="subtle-panel" Padding="16">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#F7FBFF" />
                <TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <Grid Grid.Column="1">
          <ScrollViewer IsVisible="{Binding IsOverviewSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Grid ColumnDefinitions="1.18*,0.82*" ColumnSpacing="18">
                <Border Grid.Column="0" Classes="glass-panel">
                  <StackPanel Spacing="14">
                    <TextBlock Classes="section-caption" Text="{Binding Copy.HeroEyebrow}" />
                    <TextBlock Classes="page-heading" Text="{Binding HeroTitle}" TextWrapping="Wrap" />
                    <Border Classes="metric-chip" HorizontalAlignment="Left">
                      <TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" Foreground="#E0ECFA" FontSize="16" />
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="glass-panel">
                  <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.EndpointLabel}" FontWeight="SemiBold" Foreground="#A9C1DE" />
                      <TextBlock Text="{Binding WebEndpoint}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding WebEndpoint}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.SessionLabel}" FontWeight="SemiBold" Foreground="#A9C1DE" />
                      <TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" Foreground="#A9C1DE" />
                      <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#A9C1DE" />
                      <TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </Grid>

              <Border Classes="glass-panel">
                <StackPanel Spacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <StackPanel Spacing="4">
                      <TextBlock Classes="panel-heading" Text="{Binding Copy.MainActionsTitle}" />
                      <TextBlock Text="{Binding Copy.MainActionsSummary}" Classes="secondary" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Classes="metric-chip" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Copy.ServiceControlsTitle}" Foreground="#D6E8FB" FontWeight="SemiBold" />
                    </Border>
                  </Grid>

                  <Grid ColumnDefinitions="1*,1*,1*" ColumnSpacing="12">
                    <Button Grid.Column="0" Classes="primary" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                    <Button Grid.Column="1" Classes="secondary" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                    <Button Grid.Column="2" Classes="secondary" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding Copy.OpenWebUiLabel}" />
                  </Grid>
                  <Grid ColumnDefinitions="1*,1*,1*" ColumnSpacing="12">
                    <Button Grid.Column="0" Classes="ghost" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                    <Button Grid.Column="1" Classes="ghost" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                    <Button Grid.Column="2" Classes="ghost" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                  </Grid>
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="18">
                <Border Grid.Column="0" Classes="glass-panel">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.PrimaryIssueLabel}" />
                    <Border Classes="subtle-panel"
                            IsVisible="{Binding HasPrimaryIssue}"
                            BorderBrush="{Binding HeroAccentBrush}">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold" FontSize="19" />
                        <TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PrimaryIssueDetail}" Classes="secondary" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PrimaryIssueRemediation}" Foreground="#90E7FF" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                    <Border Classes="subtle-panel"
                            IsVisible="{Binding HasNoPrimaryIssue}"
                            BorderBrush="#316288">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold" FontSize="19" />
                        <TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PrimaryIssueDetail}" Classes="secondary" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="glass-panel">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.SecondaryIssueLabel}" />
                    <Border Classes="subtle-panel" BorderBrush="#37597F">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                    <Border Classes="subtle-panel"
                            BorderBrush="#7A5266"
                            IsVisible="{Binding HasLastError}">
                      <StackPanel Spacing="8">
                        <TextBlock Text="{Binding Copy.DiagnosticsTitle}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding LastError}" Foreground="#FFD6DA" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsServiceControlsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Border Classes="glass-panel">
                <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="page-heading" Text="{Binding Copy.ServiceControlsTitle}" />
                    <TextBlock Text="{Binding Copy.ControlsIntro}" Classes="secondary" TextWrapping="Wrap" />
                    <Border Classes="metric-chip" HorizontalAlignment="Left">
                      <TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" />
                  </StackPanel>
                  <Border Grid.Column="1" Classes="subtle-panel">
                    <StackPanel Spacing="10">
                      <TextBlock Text="{Binding Copy.SessionLabel}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" Margin="0,10,0,0" />
                      <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>

              <Border Classes="glass-panel">
                <Grid ColumnDefinitions="1*,1*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                  <Button Grid.Row="0" Grid.Column="0" Classes="primary" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                  <Button Grid.Row="0" Grid.Column="1" Classes="secondary" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                  <Button Grid.Row="1" Grid.Column="0" Classes="secondary" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding Copy.OpenWebUiLabel}" />
                  <Button Grid.Row="1" Grid.Column="1" Classes="secondary" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                  <Button Grid.Row="2" Grid.Column="0" Classes="ghost" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                  <Button Grid.Row="2" Grid.Column="1" Classes="ghost" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                </Grid>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsEnvironmentSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Border Classes="glass-panel">
                <StackPanel Spacing="12">
                  <TextBlock Classes="page-heading" Text="{Binding Copy.EnvironmentTitle}" />
                  <TextBlock Text="{Binding Copy.EnvironmentIntro}" Classes="secondary" TextWrapping="Wrap" />
                  <WrapPanel>
                    <Border Classes="metric-chip">
                      <TextBlock Text="{Binding BlockingEnvironmentCheckCount, StringFormat=阻塞项 {0}}" Foreground="#FF8C99" FontWeight="SemiBold" />
                    </Border>
                    <Border Classes="metric-chip">
                      <TextBlock Text="{Binding WarningEnvironmentCheckCount, StringFormat=需注意 {0}}" Foreground="#FFC86E" FontWeight="SemiBold" />
                    </Border>
                    <Border Classes="metric-chip">
                      <TextBlock Text="{Binding ReadyEnvironmentCheckCount, StringFormat=正常 {0}}" Foreground="#63E7A8" FontWeight="SemiBold" />
                    </Border>
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border Classes="glass-panel">
                <StackPanel Spacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.BlockingGroupTitle}" />
                    <Border Grid.Column="1" Classes="metric-chip">
                      <TextBlock Text="{Binding BlockingEnvironmentCheckCount}" Foreground="#FF8C99" FontWeight="SemiBold" />
                    </Border>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding BlockingEnvironmentChecks}" IsVisible="{Binding HasBlockingEnvironmentChecks}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="subtle-panel" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,12">
                          <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="19" />
                              <Border Classes="metric-chip">
                                <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" />
                              </Border>
                            </Grid>
                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoBlockingEnvironmentChecks}" />
                </StackPanel>
              </Border>

              <Border Classes="glass-panel">
                <StackPanel Spacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.WarningGroupTitle}" />
                    <Border Grid.Column="1" Classes="metric-chip">
                      <TextBlock Text="{Binding WarningEnvironmentCheckCount}" Foreground="#FFC86E" FontWeight="SemiBold" />
                    </Border>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding WarningEnvironmentChecks}" IsVisible="{Binding HasWarningEnvironmentChecks}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="subtle-panel" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,12">
                          <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="19" />
                              <Border Classes="metric-chip">
                                <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" />
                              </Border>
                            </Grid>
                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoWarningEnvironmentChecks}" />
                </StackPanel>
              </Border>

              <Border Classes="glass-panel">
                <StackPanel Spacing="14">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.ReadyGroupTitle}" />
                    <Border Grid.Column="1" Classes="metric-chip">
                      <TextBlock Text="{Binding ReadyEnvironmentCheckCount}" Foreground="#63E7A8" FontWeight="SemiBold" />
                    </Border>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding ReadyEnvironmentChecks}" IsVisible="{Binding HasReadyEnvironmentChecks}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="subtle-panel" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,12">
                          <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="19" />
                              <Border Classes="metric-chip">
                                <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" />
                              </Border>
                            </Grid>
                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoReadyEnvironmentChecks}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsSettingsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Border Classes="glass-panel">
                <StackPanel Spacing="14">
                  <TextBlock Classes="page-heading" Text="{Binding Copy.SettingsTitle}" />
                  <TextBlock Text="{Binding Copy.SettingsIntro}" Classes="secondary" TextWrapping="Wrap" />

                  <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                    <StackPanel Grid.Row="0" Spacing="8">
                      <TextBlock Text="{Binding Copy.ServerExecutableLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding ServerExecutablePath, Mode=TwoWay}" Watermark="请输入服务端可执行文件路径" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyServerExecutableClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenServerExecutableDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                      </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="8">
                      <TextBlock Text="{Binding Copy.ConfigPathLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding ConfigPath, Mode=TwoWay}" Watermark="请输入用户配置文件路径" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyConfigPathClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenConfigDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                      </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Spacing="8">
                      <TextBlock Text="{Binding Copy.WorkdirLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding Workdir, Mode=TwoWay}" Watermark="请输入工作目录" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyWorkdirClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenWorkdirClicked" Content="{Binding Copy.OpenDirectoryLabel}" />
                      </Grid>
                    </StackPanel>

                    <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="14">
                      <Button Grid.Column="0" Classes="primary" Width="148" Click="SaveSettingsClicked" Content="{Binding Copy.SaveSettingsLabel}" />
                      <TextBlock Grid.Column="1"
                                 Text="点窗口右上角关闭时，会询问是隐藏到托盘还是完全退出。"
                                 Classes="secondary"
                                 VerticalAlignment="Center"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <ScrollViewer IsVisible="{Binding IsDiagnosticsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Border Classes="glass-panel">
                <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="page-heading" Text="{Binding Copy.DiagnosticsTitle}" />
                    <TextBlock Text="{Binding Copy.DiagnosticsIntro}" Classes="secondary" TextWrapping="Wrap" />
                    <WrapPanel>
                      <Button Classes="secondary" Margin="0,0,12,12" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                      <Button Classes="secondary" Margin="0,0,12,12" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                    </WrapPanel>
                  </StackPanel>
                  <Border Grid.Column="1" Classes="subtle-panel">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>

              <Border Classes="glass-panel">
                <StackPanel Spacing="12">
                  <TextBlock Classes="panel-heading" Text="{Binding Copy.RecentStderrTitle}" />
                  <ItemsControl ItemsSource="{Binding RecentStderr}" IsVisible="{Binding HasRecentStderr}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="14"
                                CornerRadius="16"
                                Background="#91101F36"
                                BorderBrush="#34577F"
                                BorderThickness="1">
                          <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas,monospace" Foreground="#F2F8FF" />
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding Copy.RawDiagnosticsEmpty}" Classes="secondary" IsVisible="{Binding HasNoRecentStderr}" />
                </StackPanel>
              </Border>

              <Border Classes="glass-panel">
                <StackPanel Spacing="12">
                  <TextBlock Classes="panel-heading" Text="{Binding Copy.DiagnosticsSummaryTitle}" />
                  <TextBox Text="{Binding DiagnosticsSummary}"
                           AcceptsReturn="True"
                           IsReadOnly="True"
                           TextWrapping="Wrap"
                           MinHeight="260" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Grid>
    </Grid>
  </Grid>
</Window>
