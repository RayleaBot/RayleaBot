<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RayleaBot.Launcher.MainWindow"
        Title="RayleaBot Launcher"
        Width="1240"
        Height="900"
        MinWidth="980"
        MinHeight="760"
        Background="#07111F"
        Foreground="#E5EEF8">
  <Window.Styles>
    <Style Selector="Border.card">
      <Setter Property="CornerRadius" Value="20" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="BorderBrush" Value="#20314A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#0F172A" />
    </Style>

    <Style Selector="Border.hero">
      <Setter Property="CornerRadius" Value="28" />
      <Setter Property="Padding" Value="28" />
      <Setter Property="BorderBrush" Value="#274264" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#0B162A" />
    </Style>

    <Style Selector="TextBlock.eyebrow">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#67E8F9" />
    </Style>

    <Style Selector="TextBlock.heading">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.card-heading">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.metric-pill">
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="#132238" />
      <Setter Property="BorderBrush" Value="#223554" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0891B2" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#0891B2" />
      <Setter Property="MinWidth" Value="150" />
      <Setter Property="MinHeight" Value="42" />
    </Style>

    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#132238" />
      <Setter Property="Foreground" Value="#E5EEF8" />
      <Setter Property="BorderBrush" Value="#2D4363" />
      <Setter Property="MinWidth" Value="150" />
      <Setter Property="MinHeight" Value="42" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="#0B1324" />
      <Setter Property="BorderBrush" Value="#29405F" />
      <Setter Property="Foreground" Value="#E5EEF8" />
      <Setter Property="SelectionBrush" Value="#0891B2" />
    </Style>

    <Style Selector="Expander">
      <Setter Property="Foreground" Value="#E5EEF8" />
    </Style>
  </Window.Styles>

  <ScrollViewer>
    <StackPanel Margin="24" Spacing="18">
      <Border Classes="hero">
        <Grid ColumnDefinitions="*,340" RowDefinitions="Auto,Auto,Auto" RowSpacing="14" ColumnSpacing="24">
          <StackPanel Spacing="8">
            <TextBlock Classes="eyebrow" Text="Launcher overview" />
            <TextBlock Classes="heading" Text="{Binding HeroTitle}" />
            <Border Classes="metric-pill" HorizontalAlignment="Left">
              <TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" />
            </Border>
            <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" Foreground="#C7D6E8" />
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="12">
            <StackPanel Spacing="4">
              <TextBlock Text="Endpoint" FontWeight="SemiBold" Foreground="#9FB4CF" />
              <TextBlock Text="{Binding WebEndpoint}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Session" FontWeight="SemiBold" Foreground="#9FB4CF" />
              <TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Operation" FontWeight="SemiBold" Foreground="#9FB4CF" />
              <TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="Version" FontWeight="SemiBold" Foreground="#9FB4CF" />
              <TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding VersionDetail}" TextWrapping="Wrap" Foreground="#9FB4CF" />
            </StackPanel>
          </StackPanel>

          <Border Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Classes="card"
                  IsVisible="{Binding HasPrimaryIssue}"
                  Background="#1E293B"
                  BorderBrush="#475569">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
              <Border Width="12" Height="12" CornerRadius="999" Background="{Binding HeroAccentBrush}" VerticalAlignment="Top" Margin="0,4,0,0" />
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="{Binding PrimaryIssueTitle}" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" Foreground="#D8E3F1" />
                <TextBlock Text="{Binding PrimaryIssueRemediation}" TextWrapping="Wrap" Foreground="#93C5FD" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="2"
                  Grid.ColumnSpan="2"
                  Classes="card"
                  IsVisible="{Binding HasLastError}"
                  Background="#27191A"
                  BorderBrush="#7F1D1D">
            <StackPanel Spacing="8">
              <TextBlock Text="Diagnostic detail" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="{Binding LastError}" TextWrapping="Wrap" Foreground="#FCA5A5" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid ColumnDefinitions="1.05*,0.95*" ColumnSpacing="18">
        <StackPanel Grid.Column="0" Spacing="18">
          <Border Classes="card">
            <StackPanel Spacing="14">
              <TextBlock Classes="card-heading" Text="Launcher settings" />
              <TextBlock Text="The launcher keeps only local bootstrap paths here. Platform configuration stays in default.yaml + user.yaml." Foreground="#9FB4CF" TextWrapping="Wrap" />

              <StackPanel Spacing="6">
                <TextBlock Text="Server executable path" />
                <TextBox Text="{Binding ServerExecutablePath, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="Config path" />
                <TextBox Text="{Binding ConfigPath, Mode=TwoWay}" />
              </StackPanel>

              <StackPanel Spacing="6">
                <TextBlock Text="Workdir" />
                <TextBox Text="{Binding Workdir, Mode=TwoWay}" />
              </StackPanel>

              <WrapPanel ItemHeight="42" ItemWidth="180">
                <Button Classes="secondary" Margin="0,0,10,10" Click="SaveSettingsClicked">Save settings</Button>
                <Border Classes="metric-pill" Margin="0,0,10,10" IsVisible="{Binding CloseToTrayEnabled}">
                  <TextBlock Text="Close hides to tray" Foreground="#D8E3F1" />
                </Border>
              </WrapPanel>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="14">
              <TextBlock Classes="card-heading" Text="Environment and bootstrap" />
              <TextBlock Text="Blocking issues stay visible here; bootstrap-ready warnings stay out of the hero area." Foreground="#9FB4CF" TextWrapping="Wrap" />

              <ItemsControl ItemsSource="{Binding EnvironmentChecks}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,12"
                            Padding="14"
                            CornerRadius="16"
                            BorderBrush="#24364F"
                            BorderThickness="1"
                            Background="#0B1324">
                      <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                          <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                          <Border Classes="metric-pill" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" />
                          </Border>
                        </Grid>
                        <TextBlock Text="{Binding Summary}" Foreground="#D8E3F1" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Detail}" Foreground="#9FB4CF" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="18">
          <Border Classes="card">
            <StackPanel Spacing="14">
              <TextBlock Classes="card-heading" Text="Service controls" />
              <TextBlock Text="Actions are gated by local preflight and live service state." Foreground="#9FB4CF" TextWrapping="Wrap" />

              <WrapPanel ItemHeight="42" ItemWidth="180">
                <Button Classes="primary" Margin="0,0,10,10" Click="StartClicked" IsEnabled="{Binding CanStart}">Start service</Button>
                <Button Classes="secondary" Margin="0,0,10,10" Click="StopClicked" IsEnabled="{Binding CanStop}">Stop service</Button>
                <Button Classes="secondary" Margin="0,0,10,10" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}">Open Web UI</Button>
                <Button Classes="secondary" Margin="0,0,10,10" Click="RetryClicked" IsEnabled="{Binding CanRetry}">Retry health/auth</Button>
                <Button Classes="secondary" Margin="0,0,10,10" Click="OpenLogsClicked">Open logs directory</Button>
                <Button Classes="secondary" Margin="0,0,10,10" Click="OpenReleasePageClicked" IsEnabled="{Binding CanOpenReleasePage}">Open release page</Button>
                <Button Classes="secondary" Margin="0,0,10,10" Click="CopyDiagnosticsClicked">Copy diagnostics</Button>
              </WrapPanel>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="14">
              <TextBlock Classes="card-heading" Text="Recent stderr" />
              <TextBlock Text="Raw stderr stays secondary. Use it only after checking the local issues and service state above." Foreground="#9FB4CF" TextWrapping="Wrap" />
              <ItemsControl ItemsSource="{Binding RecentStderr}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10" Padding="12" CornerRadius="14" Background="#08111F" BorderBrush="#1F3048" BorderThickness="1">
                      <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas,monospace" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Expander Header="Diagnostic summary">
                <Border Margin="0,12,0,0" Padding="12" CornerRadius="14" Background="#08111F" BorderBrush="#1F3048" BorderThickness="1">
                  <TextBox Text="{Binding DiagnosticsSummary}"
                           AcceptsReturn="True"
                           IsReadOnly="True"
                           TextWrapping="Wrap"
                           MinHeight="200" />
                </Border>
              </Expander>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</Window>
