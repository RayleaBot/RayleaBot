<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RayleaBot.Launcher.MainWindow"
        Title="{Binding Copy.WindowTitle}"
        Width="1460"
        Height="940"
        MinWidth="1220"
        MinHeight="780"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="Transparent"
        Foreground="#F5F9FF">
  <Window.Styles>
    <Style Selector="Border.shell"><Setter Property="CornerRadius" Value="30" /><Setter Property="Padding" Value="18" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#F30A1630" Offset="0" /><GradientStop Color="#ED0B1830" Offset="0.52" /><GradientStop Color="#E5091226" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#2A4868" /><Setter Property="BorderThickness" Value="1" /><Setter Property="BoxShadow" Value="0 30 64 0 #82000000" /></Style>
    <Style Selector="Border.glass-panel"><Setter Property="CornerRadius" Value="26" /><Setter Property="Padding" Value="22" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#D91A2E49" Offset="0" /><GradientStop Color="#D114243B" Offset="0.56" /><GradientStop Color="#C90E1B2F" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#315779" /><Setter Property="BorderThickness" Value="1" /><Setter Property="BoxShadow" Value="0 18 36 0 #26000000" /></Style>
    <Style Selector="Border.subtle-panel"><Setter Property="CornerRadius" Value="20" /><Setter Property="Padding" Value="18" /><Setter Property="Background" Value="#9413243D" /><Setter Property="BorderBrush" Value="#274566" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.hero-glass"><Setter Property="CornerRadius" Value="24" /><Setter Property="Padding" Value="22" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#CB18304D" Offset="0" /><GradientStop Color="#C112253E" Offset="0.6" /><GradientStop Color="#BA0D1C30" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#3A648E" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.sidebar-item"><Setter Property="CornerRadius" Value="22" /><Setter Property="Padding" Value="18,16" /><Setter Property="Background" Value="#9712233C" /><Setter Property="BorderBrush" Value="#233E5D" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.metric-chip"><Setter Property="CornerRadius" Value="999" /><Setter Property="Padding" Value="12,6" /><Setter Property="Background" Value="#8F1A304A" /><Setter Property="BorderBrush" Value="#44698F" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.titlebar-actions"><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="6" /><Setter Property="Background" Value="#73132540" /><Setter Property="BorderBrush" Value="#35597E" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="Border.environment-item"><Setter Property="CornerRadius" Value="20" /><Setter Property="Padding" Value="18" /><Setter Property="Background" Value="#90152540" /><Setter Property="BorderThickness" Value="1" /></Style>
    <Style Selector="TextBlock.page-heading"><Setter Property="FontSize" Value="34" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#FAFDFF" /></Style>
    <Style Selector="TextBlock.panel-heading"><Setter Property="FontSize" Value="24" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#F7FBFF" /></Style>
    <Style Selector="TextBlock.section-caption"><Setter Property="FontSize" Value="12" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#8FE8FF" /></Style>
    <Style Selector="TextBlock.secondary"><Setter Property="Foreground" Value="#DCE9F8" /><Setter Property="FontSize" Value="14" /></Style>
    <Style Selector="TextBlock.muted"><Setter Property="Foreground" Value="#BDD1E8" /><Setter Property="FontSize" Value="13" /></Style>
    <Style Selector="TextBox"><Setter Property="Foreground" Value="#F7FBFF" /><Setter Property="Background" Value="#AA122238" /><Setter Property="BorderBrush" Value="#4874A7" /><Setter Property="BorderThickness" Value="1" /><Setter Property="SelectionBrush" Value="#6BDFFF" /><Setter Property="CornerRadius" Value="16" /><Setter Property="Padding" Value="14,11" /></Style>
    <Style Selector="Button.primary"><Setter Property="Foreground" Value="#081D30" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#94F1FF" Offset="0" /><GradientStop Color="#3CC6EE" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#B7F7FF" /><Setter Property="BorderThickness" Value="1" /><Setter Property="MinHeight" Value="48" /><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="18,10" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
    <Style Selector="Button.primary:pointerover"><Setter Property="Foreground" Value="#051521" /><Setter Property="Background"><Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#B4F8FF" Offset="0" /><GradientStop Color="#56D7FF" Offset="1" /></LinearGradientBrush></Setter.Value></Setter><Setter Property="BorderBrush" Value="#D0FBFF" /></Style>
    <Style Selector="Button.primary:pressed"><Setter Property="Foreground" Value="#03111C" /><Setter Property="Background" Value="#38B5DA" /><Setter Property="BorderBrush" Value="#7EE8FF" /></Style>
    <Style Selector="Button.primary:disabled"><Setter Property="Foreground" Value="#D5E8FA" /><Setter Property="Background" Value="#2C5777" /><Setter Property="BorderBrush" Value="#44749A" /><Setter Property="Opacity" Value="1" /></Style>
    <Style Selector="Button.secondary"><Setter Property="Foreground" Value="#F7FBFF" /><Setter Property="Background" Value="#A1122744" /><Setter Property="BorderBrush" Value="#5B87B8" /><Setter Property="BorderThickness" Value="1" /><Setter Property="MinHeight" Value="48" /><Setter Property="CornerRadius" Value="18" /><Setter Property="Padding" Value="18,10" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
    <Style Selector="Button.secondary:pointerover"><Setter Property="Foreground" Value="#FFFFFF" /><Setter Property="Background" Value="#BC18345A" /><Setter Property="BorderBrush" Value="#82B9F0" /></Style>
    <Style Selector="Button.secondary:pressed"><Setter Property="Foreground" Value="#F7FBFF" /><Setter Property="Background" Value="#88213F66" /><Setter Property="BorderBrush" Value="#69A0D6" /></Style>
    <Style Selector="Button.secondary:disabled"><Setter Property="Foreground" Value="#D2E2F3" /><Setter Property="Background" Value="#24415D" /><Setter Property="BorderBrush" Value="#3C668D" /><Setter Property="Opacity" Value="1" /></Style>
    <Style Selector="Button.ghost"><Setter Property="Foreground" Value="#EEF6FF" /><Setter Property="Background" Value="#6E13253D" /><Setter Property="BorderBrush" Value="#416B95" /><Setter Property="BorderThickness" Value="1" /><Setter Property="CornerRadius" Value="16" /><Setter Property="Padding" Value="14,9" /><Setter Property="MinHeight" Value="42" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
    <Style Selector="Button.ghost:pointerover"><Setter Property="Foreground" Value="#FFFFFF" /><Setter Property="Background" Value="#8A1A304E" /><Setter Property="BorderBrush" Value="#79AEE0" /></Style>
    <Style Selector="Button.ghost:pressed"><Setter Property="Foreground" Value="#F4F9FF" /><Setter Property="Background" Value="#5C13243C" /><Setter Property="BorderBrush" Value="#5C87B4" /></Style>
    <Style Selector="Button.ghost:disabled"><Setter Property="Foreground" Value="#C8D8E9" /><Setter Property="Background" Value="#223B54" /><Setter Property="BorderBrush" Value="#365B7E" /><Setter Property="Opacity" Value="1" /></Style>
    <Style Selector="Button.window-button"><Setter Property="Width" Value="38" /><Setter Property="Height" Value="32" /><Setter Property="Padding" Value="0" /><Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="#F3F8FF" /><Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Setter Property="CornerRadius" Value="12" /><Setter Property="FontSize" Value="15" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
    <Style Selector="Button.window-button:pointerover"><Setter Property="Background" Value="#A01A3150" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="Button.window-button:pressed"><Setter Property="Background" Value="#7812243F" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="Button.window-close:pointerover"><Setter Property="Background" Value="#AF7B3042" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="Button.window-close:pressed"><Setter Property="Background" Value="#8D592536" /><Setter Property="Foreground" Value="#FFFFFF" /></Style>
    <Style Selector="ListBox.side-nav"><Setter Property="Background" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /></Style>
    <Style Selector="ListBox.side-nav ListBoxItem"><Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="0,0,0,12" /><Setter Property="Background" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /></Style>
  </Window.Styles>
  <Border Classes="shell" Margin="10">
    <Grid>
      <Grid IsHitTestVisible="False">
        <Border Width="420" Height="420" CornerRadius="210" Background="#1F5A98" Opacity="0.17" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-140,-170,0,0" />
        <Border Width="520" Height="520" CornerRadius="260" Background="#0DA7E9" Opacity="0.08" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-190,-150,0" />
        <Border Width="360" Height="360" CornerRadius="180" Background="#265FF0" Opacity="0.07" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,260,-120" />
      </Grid>
      <Grid RowDefinitions="Auto,*" RowSpacing="18">
        <Border Grid.Row="0" Classes="glass-panel" Padding="16,14" PointerPressed="TitleBarPointerPressed" DoubleTapped="TitleBarDoubleTapped">
          <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="16">
            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
              <Border Width="44" Height="44" CornerRadius="22" Background="#72D9FF" BorderBrush="#BDF4FF" BorderThickness="1"><Border Width="20" Height="20" CornerRadius="10" Background="#09172C" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
              <StackPanel Spacing="2"><TextBlock Text="{Binding Copy.WindowTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#FBFDFF" /><TextBlock Text="{Binding Copy.TitleBarHint}" Classes="secondary" /></StackPanel>
            </StackPanel>
            <Border Grid.Column="1" Classes="metric-chip" HorizontalAlignment="Left" VerticalAlignment="Center"><StackPanel Orientation="Horizontal" Spacing="10"><Border Width="10" Height="10" CornerRadius="5" Background="{Binding HeroAccentBrush}" VerticalAlignment="Center" /><TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" /></StackPanel></Border>
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding OperationSummary}" Foreground="#E1EBF9" TextTrimming="CharacterEllipsis" MaxWidth="440" />
            <Grid Grid.Column="3" VerticalAlignment="Center">
              <Button Classes="secondary" Click="OpenWebClicked" Content="{Binding OpenWebUiActionLabel}" IsEnabled="{Binding CanOpenWebUi}" IsVisible="{Binding IsSetupRequired}" MinWidth="168" />
              <TextBlock Text="{Binding ServiceDetail}" Foreground="#E7F0FC" MaxWidth="320" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" IsVisible="{Binding IsNotSetupRequired}" />
            </Grid>
            <Border Grid.Column="4" Classes="titlebar-actions" HorizontalAlignment="Right"><StackPanel Orientation="Horizontal" Spacing="4"><Button Classes="window-button" Click="MinimizeClicked">—</Button><Button Classes="window-button" Click="ToggleMaximizeClicked" Content="{Binding WindowStateGlyph}" /><Button Classes="window-button window-close" Click="CloseClicked">×</Button></StackPanel></Border>
          </Grid>
        </Border>
        <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="18">
          <Border Grid.Column="0" Classes="glass-panel" Padding="20">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
              <StackPanel Spacing="6"><TextBlock Text="{Binding Copy.SidebarTitle}" FontSize="17" FontWeight="SemiBold" Foreground="#F7FBFF" /><TextBlock Text="{Binding Copy.SidebarSummary}" Classes="secondary" TextWrapping="Wrap" /></StackPanel>
              <ListBox Grid.Row="1" Classes="side-nav" ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="sidebar-item" Background="{Binding BackgroundBrush}" BorderBrush="{Binding BorderBrush}">
                      <StackPanel Spacing="6"><TextBlock Text="{Binding Title}" Foreground="{Binding TitleBrush}" FontSize="18" FontWeight="SemiBold" /><TextBlock Text="{Binding Summary}" Foreground="{Binding SummaryBrush}" TextWrapping="Wrap" FontSize="13" /></StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <Border Grid.Row="2" Classes="subtle-panel" Padding="16"><StackPanel Spacing="8"><TextBlock Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#F7FBFF" /><TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" /><TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" /></StackPanel></Border>
            </Grid>
          </Border>
          <Grid Grid.Column="1">
            <ScrollViewer IsVisible="{Binding IsOverviewSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                  <Border Grid.Column="0" Classes="hero-glass">
                    <StackPanel Spacing="14">
                      <TextBlock Classes="section-caption" Text="{Binding Copy.HeroEyebrow}" />
                      <TextBlock Classes="page-heading" Text="{Binding HeroTitle}" TextWrapping="Wrap" />
                      <Border Classes="metric-chip" HorizontalAlignment="Left"><TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" /></Border>
                      <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" Foreground="#E5EEF9" FontSize="16" />
                      <Button Classes="primary" Click="OpenWebClicked" Content="{Binding Copy.OpenInitializationLabel}" IsEnabled="{Binding CanOpenWebUi}" IsVisible="{Binding IsSetupRequired}" HorizontalAlignment="Left" MinWidth="156" />
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1" Classes="glass-panel">
                    <StackPanel Spacing="14">
                      <StackPanel Spacing="4"><TextBlock Text="{Binding Copy.EndpointLabel}" FontWeight="SemiBold" Foreground="#B1C7E2" /><TextBlock Text="{Binding WebEndpoint}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding WebEndpoint}" /></StackPanel>
                      <StackPanel Spacing="4"><TextBlock Text="{Binding Copy.SessionLabel}" FontWeight="SemiBold" Foreground="#B1C7E2" /><TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap" /></StackPanel>
                      <StackPanel Spacing="4"><TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" Foreground="#B1C7E2" /><TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" /></StackPanel>
                      <StackPanel Spacing="4"><TextBlock Text="{Binding Copy.VersionLabel}" FontWeight="SemiBold" Foreground="#B1C7E2" /><TextBlock Text="{Binding VersionSummary}" TextWrapping="Wrap" /><TextBlock Text="{Binding VersionDetail}" Classes="secondary" TextWrapping="Wrap" /></StackPanel>
                    </StackPanel>
                  </Border>
                </Grid>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="16">
                    <StackPanel Spacing="4"><TextBlock Classes="panel-heading" Text="{Binding Copy.MainActionsTitle}" /><TextBlock Text="{Binding Copy.MainActionsSummary}" Classes="secondary" TextWrapping="Wrap" /></StackPanel>
                    <WrapPanel ItemWidth="208" ItemHeight="56" Orientation="Horizontal">
                      <Button Classes="primary" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                      <Button Classes="secondary" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                      <Button Classes="secondary" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding OpenWebUiActionLabel}" />
                      <Button Classes="ghost" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                      <Button Classes="ghost" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                      <Button Classes="ghost" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                    </WrapPanel>
                  </StackPanel>
                </Border>
                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="18">
                  <Border Grid.Column="0" Classes="glass-panel">
                    <StackPanel Spacing="12">
                      <TextBlock Classes="panel-heading" Text="{Binding Copy.PrimaryIssueLabel}" />
                      <Border Classes="subtle-panel" IsVisible="{Binding HasPrimaryIssue}" BorderBrush="{Binding HeroAccentBrush}">
                        <StackPanel Spacing="8"><TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold" FontSize="19" /><TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" /><TextBlock Text="{Binding PrimaryIssueDetail}" Classes="secondary" TextWrapping="Wrap" /><TextBlock Text="{Binding PrimaryIssueRemediation}" Foreground="{Binding HeroAccentBrush}" TextWrapping="Wrap" /></StackPanel>
                      </Border>
                      <Border Classes="subtle-panel" IsVisible="{Binding HasNoPrimaryIssue}" BorderBrush="#335C84">
                        <StackPanel Spacing="8"><TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold" FontSize="19" /><TextBlock Text="{Binding PrimaryIssueSummary}" TextWrapping="Wrap" /><TextBlock Text="{Binding PrimaryIssueDetail}" Classes="secondary" TextWrapping="Wrap" /></StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>
                  <Border Grid.Column="1" Classes="glass-panel">
                    <StackPanel Spacing="12">
                      <TextBlock Classes="panel-heading" Text="{Binding Copy.SecondaryIssueLabel}" />
                      <Border Classes="subtle-panel" BorderBrush="#385C82"><StackPanel Spacing="8"><TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" /><TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" /></StackPanel></Border>
                      <Border Classes="subtle-panel" BorderBrush="#785262" IsVisible="{Binding HasLastError}"><StackPanel Spacing="8"><TextBlock Text="{Binding Copy.DiagnosticsTitle}" FontWeight="SemiBold" /><TextBlock Text="{Binding LastError}" Foreground="#FFE2E6" TextWrapping="Wrap" /></StackPanel></Border>
                    </StackPanel>
                  </Border>
                </Grid>
              </StackPanel>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsServiceControlsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                    <StackPanel Spacing="12">
                      <TextBlock Classes="page-heading" Text="{Binding Copy.ServiceControlsTitle}" />
                      <TextBlock Text="{Binding Copy.ControlsIntro}" Classes="secondary" TextWrapping="Wrap" />
                      <Border Classes="metric-chip" HorizontalAlignment="Left"><TextBlock Text="{Binding StatusSummary}" Foreground="{Binding HeroAccentBrush}" FontWeight="SemiBold" /></Border>
                      <TextBlock Text="{Binding ServiceDetail}" TextWrapping="Wrap" />
                      <Button Classes="primary" Click="OpenWebClicked" Content="{Binding Copy.OpenInitializationLabel}" IsEnabled="{Binding CanOpenWebUi}" IsVisible="{Binding IsSetupRequired}" HorizontalAlignment="Left" MinWidth="156" />
                    </StackPanel>
                    <Border Grid.Column="1" Classes="subtle-panel"><StackPanel Spacing="10"><TextBlock Text="{Binding Copy.SessionLabel}" FontWeight="SemiBold" /><TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap" /><TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" Margin="0,10,0,0" /><TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" /></StackPanel></Border>
                  </Grid>
                </Border>
                <Border Classes="glass-panel">
                  <WrapPanel ItemWidth="230" ItemHeight="58" Orientation="Horizontal">
                    <Button Classes="primary" Click="StartClicked" IsEnabled="{Binding CanStart}" Content="{Binding Copy.StartServiceLabel}" />
                    <Button Classes="secondary" Click="StopClicked" IsEnabled="{Binding CanStop}" Content="{Binding Copy.StopServiceLabel}" />
                    <Button Classes="secondary" Click="OpenWebClicked" IsEnabled="{Binding CanOpenWebUi}" Content="{Binding OpenWebUiActionLabel}" />
                    <Button Classes="secondary" Click="RetryClicked" IsEnabled="{Binding CanRetry}" Content="{Binding Copy.RetryHealthAuthLabel}" />
                    <Button Classes="ghost" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                    <Button Classes="ghost" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                  </WrapPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsEnvironmentSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="page-heading" Text="{Binding Copy.EnvironmentTitle}" />
                    <TextBlock Text="{Binding Copy.EnvironmentIntro}" Classes="secondary" TextWrapping="Wrap" />
                    <WrapPanel>
                      <Border Classes="metric-chip"><TextBlock Text="{Binding BlockingEnvironmentCheckCount, StringFormat=阻塞项 {0}}" Foreground="#FF8C99" FontWeight="SemiBold" /></Border>
                      <Border Classes="metric-chip"><TextBlock Text="{Binding WarningEnvironmentCheckCount, StringFormat=需注意 {0}}" Foreground="#FFC86E" FontWeight="SemiBold" /></Border>
                      <Border Classes="metric-chip"><TextBlock Text="{Binding ReadyEnvironmentCheckCount, StringFormat=正常 {0}}" Foreground="#63E7A8" FontWeight="SemiBold" /></Border>
                    </WrapPanel>
                  </StackPanel>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12"><TextBlock Classes="panel-heading" Text="{Binding Copy.BlockingGroupTitle}" /><Border Grid.Column="1" Classes="metric-chip"><TextBlock Text="{Binding BlockingEnvironmentCheckCount}" Foreground="#FF8C99" FontWeight="SemiBold" /></Border></Grid>
                    <ItemsControl ItemsSource="{Binding BlockingEnvironmentChecks}" IsVisible="{Binding HasBlockingEnvironmentChecks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="environment-item" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,12">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="8">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="18" />
                              <Border Grid.Column="1" Classes="metric-chip" VerticalAlignment="Top"><TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" /></Border>
                              <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Summary}" TextWrapping="Wrap" />
                              <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                              <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoBlockingEnvironmentChecks}" />
                  </StackPanel>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12"><TextBlock Classes="panel-heading" Text="{Binding Copy.WarningGroupTitle}" /><Border Grid.Column="1" Classes="metric-chip"><TextBlock Text="{Binding WarningEnvironmentCheckCount}" Foreground="#FFC86E" FontWeight="SemiBold" /></Border></Grid>
                    <ItemsControl ItemsSource="{Binding WarningEnvironmentChecks}" IsVisible="{Binding HasWarningEnvironmentChecks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="environment-item" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,12">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="8">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="18" />
                              <Border Grid.Column="1" Classes="metric-chip" VerticalAlignment="Top"><TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" /></Border>
                              <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Summary}" TextWrapping="Wrap" />
                              <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                              <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding Remediation}" Foreground="{Binding AccentBrush}" TextWrapping="Wrap" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoWarningEnvironmentChecks}" />
                  </StackPanel>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12"><TextBlock Classes="panel-heading" Text="{Binding Copy.ReadyGroupTitle}" /><Border Grid.Column="1" Classes="metric-chip"><TextBlock Text="{Binding ReadyEnvironmentCheckCount}" Foreground="#63E7A8" FontWeight="SemiBold" /></Border></Grid>
                    <ItemsControl ItemsSource="{Binding ReadyEnvironmentChecks}" IsVisible="{Binding HasReadyEnvironmentChecks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="environment-item" BorderBrush="{Binding AccentBrush}" Margin="0,0,0,12">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="8">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="18" />
                              <Border Grid.Column="1" Classes="metric-chip" VerticalAlignment="Top"><TextBlock Text="{Binding SeverityLabel}" Foreground="{Binding AccentBrush}" FontWeight="SemiBold" /></Border>
                              <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Summary}" TextWrapping="Wrap" />
                              <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Detail}" Classes="secondary" TextWrapping="Wrap" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.EmptyGroupHint}" Classes="secondary" IsVisible="{Binding HasNoReadyEnvironmentChecks}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsSettingsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <StackPanel Spacing="16">
                    <TextBlock Classes="page-heading" Text="{Binding Copy.SettingsTitle}" />
                    <TextBlock Text="{Binding Copy.SettingsIntro}" Classes="secondary" TextWrapping="Wrap" />
                    <StackPanel Spacing="14">
                      <TextBlock Text="{Binding Copy.ServerExecutableLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding ServerExecutablePath, Mode=TwoWay}" Watermark="请输入服务端可执行文件路径" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyServerExecutableClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenServerExecutableDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                      </Grid>
                      <TextBlock Text="{Binding Copy.ConfigPathLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding ConfigPath, Mode=TwoWay}" Watermark="请输入用户配置文件路径" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyConfigPathClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenConfigDirectoryClicked" Content="{Binding Copy.OpenParentDirectoryLabel}" />
                      </Grid>
                      <TextBlock Text="{Binding Copy.WorkdirLabel}" FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <TextBox Grid.Column="0" Text="{Binding Workdir, Mode=TwoWay}" Watermark="请输入工作目录" />
                        <Button Grid.Column="1" Classes="ghost" Click="CopyWorkdirClicked" Content="{Binding Copy.CopyPathLabel}" />
                        <Button Grid.Column="2" Classes="ghost" Click="OpenWorkdirClicked" Content="{Binding Copy.OpenDirectoryLabel}" />
                      </Grid>
                      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="0,4,0,0">
                        <Button Grid.Column="0" Classes="primary" Width="148" Click="SaveSettingsClicked" Content="{Binding Copy.SaveSettingsLabel}" />
                        <TextBlock Grid.Column="1" Text="关闭窗口时会询问是隐藏到托盘还是完全退出。" Classes="secondary" VerticalAlignment="Center" TextWrapping="Wrap" />
                      </Grid>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <ScrollViewer IsVisible="{Binding IsDiagnosticsSectionActive}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="18">
                <Border Classes="glass-panel">
                  <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="18">
                    <StackPanel Spacing="12">
                      <TextBlock Classes="page-heading" Text="{Binding Copy.DiagnosticsTitle}" />
                      <TextBlock Text="{Binding Copy.DiagnosticsIntro}" Classes="secondary" TextWrapping="Wrap" />
                      <WrapPanel>
                        <Button Classes="secondary" Margin="0,0,12,12" Click="OpenLogsClicked" Content="{Binding Copy.OpenLogsDirectoryLabel}" />
                        <Button Classes="secondary" Margin="0,0,12,12" Click="CopyDiagnosticsClicked" Content="{Binding Copy.CopyDiagnosticsLabel}" />
                      </WrapPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Classes="subtle-panel"><StackPanel Spacing="8"><TextBlock Text="{Binding Copy.OperationLabel}" FontWeight="SemiBold" /><TextBlock Text="{Binding OperationSummary}" TextWrapping="Wrap" /></StackPanel></Border>
                  </Grid>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-heading" Text="{Binding Copy.RecentStderrTitle}" />
                    <ItemsControl ItemsSource="{Binding RecentStderr}" IsVisible="{Binding HasRecentStderr}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10" Padding="14" CornerRadius="16" Background="#93111F36" BorderBrush="#35587F" BorderThickness="1">
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Cascadia Mono,Consolas,monospace" Foreground="#F5FAFF" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding Copy.RawDiagnosticsEmpty}" Classes="secondary" IsVisible="{Binding HasNoRecentStderr}" />
                  </StackPanel>
                </Border>
                <Border Classes="glass-panel">
                  <StackPanel Spacing="12"><TextBlock Classes="panel-heading" Text="{Binding Copy.DiagnosticsSummaryTitle}" /><TextBox Text="{Binding DiagnosticsSummary}" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" MinHeight="260" /></StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
