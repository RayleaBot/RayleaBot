<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="RayleaBot.Launcher.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <sty:FluentAvaloniaTheme />
    <StyleInclude Source="avares://RayleaBot.Launcher/Styles/LauncherTokens.axaml" />
    <StyleInclude Source="avares://RayleaBot.Launcher/Styles/LauncherControls.axaml" />
  </Application.Styles>
</Application>
