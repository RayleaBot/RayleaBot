<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RayleaBot.Launcher"
             x:Class="RayleaBot.Launcher.Views.EnvironmentPage"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Classes="page-root">
      <Border Classes="compact-page-header">
        <StackPanel Spacing="4">
          <TextBlock Classes="caption" Text="{CompiledBinding Copy.EnvironmentPageHeading}" />
          <TextBlock Classes="page-title" Text="{CompiledBinding Copy.EnvironmentTitle}" />
          <TextBlock Classes="secondary"
                     Text="{CompiledBinding Copy.EnvironmentPageSummary}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Classes="toolbar-card">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <WrapPanel>
            <Border Classes="badge" Margin="0,0,8,8">
              <TextBlock Text="{CompiledBinding BlockingEnvironmentCheckCount, StringFormat=阻塞项 {0}}"
                         Foreground="{StaticResource Brush.Error}"
                         FontWeight="SemiBold" />
            </Border>
            <Border Classes="badge" Margin="0,0,8,8">
              <TextBlock Text="{CompiledBinding WarningEnvironmentCheckCount, StringFormat=需注意 {0}}"
                         Foreground="{StaticResource Brush.Warning}"
                         FontWeight="SemiBold" />
            </Border>
            <Border Classes="badge" Margin="0,0,8,8">
              <TextBlock Text="{CompiledBinding ReadyEnvironmentCheckCount, StringFormat=正常 {0}}"
                         Foreground="{StaticResource Brush.Success}"
                         FontWeight="SemiBold" />
            </Border>
          </WrapPanel>

          <Button Grid.Column="1"
                  Theme="{StaticResource ToolbarActionButton}"
                  Content="{CompiledBinding RetryActionDisplayLabel}"
                  IsEnabled="{CompiledBinding CanRetry}"
                  Click="RetryClicked"
                  VerticalAlignment="Top" />
        </Grid>
      </Border>

      <Border Classes="section-card">
        <Expander IsExpanded="True">
          <Expander.Header>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock FontWeight="SemiBold" Text="{CompiledBinding Copy.BlockingGroupTitle}" />
              <Border Grid.Column="1" Classes="badge">
                <TextBlock Text="{CompiledBinding BlockingEnvironmentCheckCount}"
                           Foreground="{StaticResource Brush.Error}"
                           FontWeight="SemiBold" />
              </Border>
            </Grid>
          </Expander.Header>

          <StackPanel Margin="0,8,0,0" Spacing="8">
            <ItemsControl ItemsSource="{CompiledBinding BlockingEnvironmentChecks}"
                          IsVisible="{CompiledBinding HasBlockingEnvironmentChecks}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:EnvironmentCheckViewModel">
                  <Border Classes="check-item" Margin="0,0,0,6">
                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{CompiledBinding Title}" />
                          <TextBlock Classes="secondary"
                                     Text="{CompiledBinding Summary}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1" Classes="badge" VerticalAlignment="Top">
                          <TextBlock Text="{CompiledBinding SeverityLabel}"
                                     Foreground="{CompiledBinding AccentBrush}"
                                     FontWeight="SemiBold" />
                        </Border>
                      </Grid>

                      <StackPanel Spacing="2" IsVisible="{CompiledBinding HasDetail}">
                        <TextBlock Classes="caption" Text="证据" />
                        <TextBlock Classes="secondary"
                                   Text="{CompiledBinding Detail}"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <StackPanel Spacing="2" IsVisible="{CompiledBinding HasRemediation}">
                        <TextBlock Classes="caption" Text="处理建议" />
                        <TextBlock Classes="secondary"
                                   Text="{CompiledBinding Remediation}"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <WrapPanel>
                        <Button Theme="{StaticResource ToolbarActionButton}"
                                Classes="inline-button"
                                Content="复制证据"
                                Tag="{CompiledBinding Detail}"
                                Click="CopyEvidenceClicked"
                                Margin="0,0,8,8" />
                        <Button Theme="{StaticResource ToolbarActionButton}"
                                Classes="inline-button"
                                Content="打开位置"
                                Tag="{CompiledBinding LocationPath}"
                                Click="OpenLocationClicked"
                                Margin="0,0,8,8"
                                IsVisible="{CompiledBinding HasLocationPath}" />
                        <Button Theme="{StaticResource ToolbarActionButton}"
                                Classes="inline-button"
                                Content="重新检查"
                                Click="RetryClicked"
                                Margin="0,0,8,8" />
                      </WrapPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="empty-state"
                    IsVisible="{CompiledBinding HasNoBlockingEnvironmentChecks}">
              <TextBlock Classes="secondary" Text="{CompiledBinding Copy.EmptyGroupHint}" />
            </Border>
          </StackPanel>
        </Expander>
      </Border>

      <Border Classes="section-card">
        <Expander IsExpanded="True">
          <Expander.Header>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock FontWeight="SemiBold" Text="{CompiledBinding Copy.WarningGroupTitle}" />
              <Border Grid.Column="1" Classes="badge">
                <TextBlock Text="{CompiledBinding WarningEnvironmentCheckCount}"
                           Foreground="{StaticResource Brush.Warning}"
                           FontWeight="SemiBold" />
              </Border>
            </Grid>
          </Expander.Header>

          <StackPanel Margin="0,8,0,0" Spacing="8">
            <ItemsControl ItemsSource="{CompiledBinding WarningEnvironmentChecks}"
                          IsVisible="{CompiledBinding HasWarningEnvironmentChecks}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:EnvironmentCheckViewModel">
                  <Border Classes="check-item" Margin="0,0,0,6">
                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{CompiledBinding Title}" />
                          <TextBlock Classes="secondary"
                                     Text="{CompiledBinding Summary}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1" Classes="badge" VerticalAlignment="Top">
                          <TextBlock Text="{CompiledBinding SeverityLabel}"
                                     Foreground="{CompiledBinding AccentBrush}"
                                     FontWeight="SemiBold" />
                        </Border>
                      </Grid>

                      <StackPanel Spacing="2" IsVisible="{CompiledBinding HasDetail}">
                        <TextBlock Classes="caption" Text="证据" />
                        <TextBlock Classes="secondary"
                                   Text="{CompiledBinding Detail}"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <StackPanel Spacing="2" IsVisible="{CompiledBinding HasRemediation}">
                        <TextBlock Classes="caption" Text="处理建议" />
                        <TextBlock Classes="secondary"
                                   Text="{CompiledBinding Remediation}"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <WrapPanel>
                        <Button Theme="{StaticResource ToolbarActionButton}"
                                Classes="inline-button"
                                Content="复制证据"
                                Tag="{CompiledBinding Detail}"
                                Click="CopyEvidenceClicked"
                                Margin="0,0,8,8" />
                        <Button Theme="{StaticResource ToolbarActionButton}"
                                Classes="inline-button"
                                Content="打开位置"
                                Tag="{CompiledBinding LocationPath}"
                                Click="OpenLocationClicked"
                                Margin="0,0,8,8"
                                IsVisible="{CompiledBinding HasLocationPath}" />
                        <Button Theme="{StaticResource ToolbarActionButton}"
                                Classes="inline-button"
                                Content="重新检查"
                                Click="RetryClicked"
                                Margin="0,0,8,8" />
                      </WrapPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="empty-state"
                    IsVisible="{CompiledBinding HasNoWarningEnvironmentChecks}">
              <TextBlock Classes="secondary" Text="{CompiledBinding Copy.EmptyGroupHint}" />
            </Border>
          </StackPanel>
        </Expander>
      </Border>

      <Border Classes="section-card">
        <Expander IsExpanded="False">
          <Expander.Header>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock FontWeight="SemiBold" Text="{CompiledBinding Copy.ReadyGroupTitle}" />
              <Border Grid.Column="1" Classes="badge">
                <TextBlock Text="{CompiledBinding ReadyEnvironmentCheckCount}"
                           Foreground="{StaticResource Brush.Success}"
                           FontWeight="SemiBold" />
              </Border>
            </Grid>
          </Expander.Header>

          <StackPanel Margin="0,8,0,0" Spacing="8">
            <ItemsControl ItemsSource="{CompiledBinding ReadyEnvironmentChecks}"
                          IsVisible="{CompiledBinding HasReadyEnvironmentChecks}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:EnvironmentCheckViewModel">
                  <Border Classes="check-item" Margin="0,0,0,6">
                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                          <TextBlock FontWeight="SemiBold" Text="{CompiledBinding Title}" />
                          <TextBlock Classes="secondary"
                                     Text="{CompiledBinding Summary}"
                                     TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1" Classes="badge" VerticalAlignment="Top">
                          <TextBlock Text="{CompiledBinding SeverityLabel}"
                                     Foreground="{CompiledBinding AccentBrush}"
                                     FontWeight="SemiBold" />
                        </Border>
                      </Grid>

                      <StackPanel Spacing="2" IsVisible="{CompiledBinding HasDetail}">
                        <TextBlock Classes="caption" Text="证据" />
                        <TextBlock Classes="secondary"
                                   Text="{CompiledBinding Detail}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="empty-state"
                    IsVisible="{CompiledBinding HasNoReadyEnvironmentChecks}">
              <TextBlock Classes="secondary" Text="{CompiledBinding Copy.EmptyGroupHint}" />
            </Border>
          </StackPanel>
        </Expander>
      </Border>

      <Border Classes="info-strip"
              IsVisible="{CompiledBinding HasEnvironmentPackagingNotice}">
        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="{CompiledBinding Copy.PackagingInfoTitle}" />
          <TextBlock Classes="secondary"
                     Text="{CompiledBinding Copy.PackagingInfoSummary}"
                     TextWrapping="Wrap" />
          <TextBlock Text="{CompiledBinding EnvironmentPackagingSummary}" TextWrapping="Wrap" />
          <TextBlock Classes="secondary"
                     Text="{CompiledBinding EnvironmentPackagingDetail}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
