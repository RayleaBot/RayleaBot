<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RayleaBot.Launcher"
             x:Class="RayleaBot.Launcher.Views.StatusPage"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Classes="page-root">
      <Border Classes="hero-header">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <StackPanel Spacing="4">
            <TextBlock Classes="caption" Text="{CompiledBinding Copy.StatusPageHeading}" />
            <TextBlock Classes="page-title" Text="{CompiledBinding HeroTitle}" TextWrapping="Wrap" />
            <TextBlock Classes="secondary" Text="{CompiledBinding ServiceDetail}" TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Column="1"
                  Classes="badge"
                  VerticalAlignment="Top">
            <TextBlock Text="{CompiledBinding StatusSummary}"
                       Foreground="{CompiledBinding HeroAccentBrush}"
                       FontWeight="SemiBold" />
          </Border>
        </Grid>
      </Border>

      <Border Classes="issue-banner"
              IsVisible="{CompiledBinding HasHomeAlert}">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
          <Border Width="4"
                  CornerRadius="{StaticResource Radius.Pill}"
                  Background="{StaticResource Brush.Warning}" />

          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock FontWeight="SemiBold"
                       Text="{CompiledBinding HomeAlertTitle}" />
            <TextBlock Classes="secondary"
                       Text="{CompiledBinding HomeAlertMessage}"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Button Grid.Column="2"
                  Theme="{StaticResource ToolbarActionButton}"
                  Content="{CompiledBinding Copy.MainAlertActionLabel}"
                  Click="HomeAlertActionClicked"
                  VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Grid ColumnDefinitions="1.4*,1*"
            ColumnSpacing="14">
        <Border Classes="app-card" VerticalAlignment="Top">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="{CompiledBinding Copy.ServiceInfoTitle}" />
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="16"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="6">
              <TextBlock Classes="meta-label" Text="{CompiledBinding Copy.StatusLabel}" />
              <TextBlock Grid.Column="1" Classes="meta-value" Text="{CompiledBinding StatusSummary}" />

              <TextBlock Grid.Row="1" Classes="meta-label" Text="{CompiledBinding Copy.EndpointLabel}" />
              <TextBlock Grid.Row="1"
                         Grid.Column="1"
                         Classes="meta-value"
                         Text="{CompiledBinding WebEndpoint}"
                         TextWrapping="Wrap" />

              <TextBlock Grid.Row="2" Classes="meta-label" Text="{CompiledBinding Copy.VersionLabel}" />
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                <TextBlock Classes="meta-value" Text="{CompiledBinding VersionSummary}" TextWrapping="Wrap" />
                <TextBlock Classes="secondary" Text="{CompiledBinding VersionDetail}" TextWrapping="Wrap" />
              </StackPanel>

              <TextBlock Grid.Row="3"
                         Classes="meta-label"
                         Text="{CompiledBinding Copy.ProcessIdLabel}"
                         IsVisible="{CompiledBinding HasProcessId}" />
              <TextBlock Grid.Row="3"
                         Grid.Column="1"
                         Classes="meta-value"
                         Text="{CompiledBinding ProcessIdSummary}"
                         IsVisible="{CompiledBinding HasProcessId}" />

              <TextBlock Grid.Row="4" Classes="meta-label" Text="{CompiledBinding Copy.WorkdirLabel}" />
              <TextBlock Grid.Row="4"
                         Grid.Column="1"
                         Classes="meta-value"
                         Text="{CompiledBinding Workdir}"
                         TextWrapping="Wrap" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="app-card" VerticalAlignment="Top">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="{CompiledBinding Copy.EnvironmentSummaryTitle}" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
              <Border Classes="metric-tile">
                <StackPanel Spacing="2">
                  <TextBlock Classes="caption" Text="阻塞项" />
                  <TextBlock FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.Error}"
                             Text="{CompiledBinding BlockingEnvironmentCheckCount}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Classes="metric-tile">
                <StackPanel Spacing="2">
                  <TextBlock Classes="caption" Text="需注意" />
                  <TextBlock FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.Warning}"
                             Text="{CompiledBinding WarningEnvironmentCheckCount}" />
                </StackPanel>
              </Border>

              <Border Grid.Column="2" Classes="metric-tile">
                <StackPanel Spacing="2">
                  <TextBlock Classes="caption" Text="正常" />
                  <TextBlock FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.Success}"
                             Text="{CompiledBinding ReadyEnvironmentCheckCount}" />
                </StackPanel>
              </Border>
            </Grid>

          </StackPanel>
        </Border>
      </Grid>

      <Grid ColumnDefinitions="1.12*,0.88*"
            ColumnSpacing="14">
        <Border Classes="app-card" VerticalAlignment="Top">
          <StackPanel Spacing="10">
            <StackPanel Spacing="3">
              <TextBlock Classes="section-title" Text="{CompiledBinding Copy.PrimaryActionTitle}" />
              <TextBlock Classes="secondary"
                         Text="{CompiledBinding OperationSummary}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Button Theme="{StaticResource PrimaryActionButton}"
                    Content="{CompiledBinding PrimaryActionDisplayLabel}"
                    IsEnabled="{CompiledBinding CanRunPrimaryAction}"
                    Click="PrimaryActionClicked"
                    HorizontalAlignment="Left" />

            <WrapPanel>
              <Button Theme="{StaticResource DangerActionButton}"
                      Content="{CompiledBinding StopActionDisplayLabel}"
                      IsEnabled="{CompiledBinding CanStop}"
                      Click="StopClicked"
                      Margin="0,0,8,8" />
              <Button Theme="{StaticResource ToolbarActionButton}"
                      Content="{CompiledBinding RetryActionDisplayLabel}"
                      IsEnabled="{CompiledBinding CanRetry}"
                      Click="RetryClicked"
                      Margin="0,0,8,8" />
              <Button Theme="{StaticResource ToolbarActionButton}"
                      Content="{CompiledBinding OpenLogsActionDisplayLabel}"
                      Click="OpenLogsClicked"
                      Margin="0,0,8,8" />
              <Button Theme="{StaticResource ToolbarActionButton}"
                      Content="{CompiledBinding Copy.CopyDiagnosticsLabel}"
                      Click="CopyDiagnosticsClicked"
                      Margin="0,0,8,8" />
            </WrapPanel>

            <Border Classes="summary-strip"
                    IsVisible="{CompiledBinding IsActionInProgress}">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <ProgressBar Classes="action-progress" IsIndeterminate="True" />
                <TextBlock Classes="secondary"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{CompiledBinding PendingActionMessage}"
                           TextWrapping="Wrap" />
              </Grid>
            </Border>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="app-card" VerticalAlignment="Top">
          <StackPanel Spacing="8">
            <TextBlock Classes="section-title" Text="{CompiledBinding Copy.RecentLogsTitle}" />

            <ItemsControl ItemsSource="{CompiledBinding HomeRecentStderr}"
                          IsVisible="{CompiledBinding HasHomeRecentStderr}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="log-panel" Margin="0,0,0,8">
                    <TextBlock Text="{Binding}"
                               FontFamily="{StaticResource FontFamily.Mono}"
                               TextWrapping="Wrap" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="empty-state"
                    IsVisible="{CompiledBinding HasNoHomeRecentStderr}">
              <TextBlock Classes="secondary"
                         Text="{CompiledBinding Copy.RecentLogsEmpty}"
                         TextWrapping="Wrap" />
            </Border>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
