<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- ============================================================
       SHELL SURFACE CLASSES
       Transparent to let Mica backdrop show through
       ============================================================ -->
  <Style Selector="Border.shell-pane">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.shell-content">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- ============================================================
       PAGE STRUCTURE PATTERNS
       ============================================================ -->
  <Style Selector="StackPanel.page-root">
    <Setter Property="Spacing" Value="{StaticResource Spacing.MD}" />
    <Setter Property="Margin" Value="0,0,0,12" />
  </Style>

  <!-- ============================================================
       HEADER PATTERNS — transparent over Mica backdrop
       ============================================================ -->
  <Style Selector="Border.page-header">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.PageHeaderPadding}" />
  </Style>

  <Style Selector="Border.compact-page-header">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="Border.hero-header">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
    <Setter Property="Padding" Value="16,14" />
  </Style>

  <!-- ============================================================
       CARD PATTERNS — transparent backgrounds so Mica shows through
       ============================================================ -->
  <Style Selector="Border.toolbar-card">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.CompactCardPadding}" />
  </Style>

  <Style Selector="Border.section-card">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.issue-banner">
    <Setter Property="Background" Value="#66241B10" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Warning}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="Border.metric-tile">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Border.check-item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.info-strip">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Border.log-panel">
    <Setter Property="Background" Value="#660E141C" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="10" />
  </Style>

  <Style Selector="Border.empty-state">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="Border.summary-strip">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="Border.dialog-surface">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <!-- ============================================================
       COMMAND BAR PATTERN
       Floating action bar for primary/secondary actions
       ============================================================ -->
  <Style Selector="Border.command-bar-pattern">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.CommandBarPadding}" />
  </Style>

  <!-- ============================================================
       STATUS BADGE PATTERNS — semi-transparent for status color
       ============================================================ -->
  <Style Selector="Border.status-badge-blocking">
    <Setter Property="Background" Value="#662A161A" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Error}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.status-badge-warning">
    <Setter Property="Background" Value="#66241B10" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Warning}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.status-badge-ready">
    <Setter Property="Background" Value="#66132018" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Success}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <!-- ============================================================
       DIVIDER
       ============================================================ -->
  <Style Selector="Border.separator">
    <Setter Property="Background" Value="{StaticResource Brush.BorderSubtle}" />
    <Setter Property="Height" Value="1" />
  </Style>

  <!-- ============================================================
       LAYOUT HELPERS
       ============================================================ -->
  <Style Selector="StackPanel.path-row">
    <Setter Property="Spacing" Value="10" />
  </Style>

  <Style Selector="WrapPanel.inline-actions">
    <Setter Property="ItemWidth" Value="NaN" />
  </Style>

  <!-- ============================================================
       ANIMATED REVEAL PATTERN
       ============================================================ -->
  <Style Selector="Border.reveal-item">
    <Setter Property="Opacity" Value="0" />
    <Setter Property="RenderTransformOrigin" Value="50%,0%" />
  </Style>
</Styles>
