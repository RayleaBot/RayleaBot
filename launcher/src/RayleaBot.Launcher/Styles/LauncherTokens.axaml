<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Color x:Key="Color.Background">#0B1220</Color>
    <Color x:Key="Color.Surface">#111827</Color>
    <Color x:Key="Color.SurfaceAlt">#162033</Color>
    <Color x:Key="Color.SurfaceMuted">#0F172A</Color>
    <Color x:Key="Color.SurfaceHover">#1B2940</Color>
    <Color x:Key="Color.SurfacePressed">#22314A</Color>
    <Color x:Key="Color.StrokeSubtle">#24FFFFFF</Color>
    <Color x:Key="Color.StrokeStrong">#3B82F6</Color>
    <Color x:Key="Color.TextPrimary">#F8FAFC</Color>
    <Color x:Key="Color.TextSecondary">#94A3B8</Color>
    <Color x:Key="Color.TextMuted">#64748B</Color>
    <Color x:Key="Color.Accent">#38BDF8</Color>
    <Color x:Key="Color.AccentHover">#63CBF9</Color>
    <Color x:Key="Color.AccentPressed">#1EA6E4</Color>
    <Color x:Key="Color.AccentForeground">#07121C</Color>
    <Color x:Key="Color.Success">#22C55E</Color>
    <Color x:Key="Color.Warning">#F59E0B</Color>
    <Color x:Key="Color.Error">#EF4444</Color>
    <Color x:Key="Color.ErrorSurface">#2B1217</Color>
    <Color x:Key="Color.ErrorSurfaceHover">#3A161C</Color>
    <Color x:Key="Color.ErrorSurfacePressed">#471B23</Color>

    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="{StaticResource Color.SurfaceMuted}" />
    <SolidColorBrush x:Key="Brush.SurfaceHover" Color="{StaticResource Color.SurfaceHover}" />
    <SolidColorBrush x:Key="Brush.SurfacePressed" Color="{StaticResource Color.SurfacePressed}" />
    <SolidColorBrush x:Key="Brush.StrokeSubtle" Color="{StaticResource Color.StrokeSubtle}" />
    <SolidColorBrush x:Key="Brush.StrokeStrong" Color="{StaticResource Color.StrokeStrong}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="{StaticResource Color.AccentPressed}" />
    <SolidColorBrush x:Key="Brush.AccentForeground" Color="{StaticResource Color.AccentForeground}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}" />
    <SolidColorBrush x:Key="Brush.ErrorSurface" Color="{StaticResource Color.ErrorSurface}" />
    <SolidColorBrush x:Key="Brush.ErrorSurfaceHover" Color="{StaticResource Color.ErrorSurfaceHover}" />
    <SolidColorBrush x:Key="Brush.ErrorSurfacePressed" Color="{StaticResource Color.ErrorSurfacePressed}" />

    <CornerRadius x:Key="Radius.Small">8</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">12</CornerRadius>
    <CornerRadius x:Key="Radius.Large">16</CornerRadius>

    <Thickness x:Key="Thickness.CardPadding">20</Thickness>
    <Thickness x:Key="Thickness.SectionGap">0,0,0,20</Thickness>

    <x:Double x:Key="Font.PageTitle">24</x:Double>
    <x:Double x:Key="Font.SectionTitle">18</x:Double>
    <x:Double x:Key="Font.Body">14</x:Double>
    <x:Double x:Key="Font.Caption">12</x:Double>
  </Styles.Resources>
</Styles>
