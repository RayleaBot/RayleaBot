<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:FluentAvalonia.UI.Controls">
  <Styles.Resources>
    <ControlTheme x:Key="PrimaryActionButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource Brush.AccentForeground}" />
      <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Style Selector="^:pointerover">
        <Setter Property="Background" Value="{StaticResource Brush.AccentHover}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentHover}" />
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Background" Value="{StaticResource Brush.AccentPressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentPressed}" />
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceHover}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
      </Style>
    </ControlTheme>

    <ControlTheme x:Key="SecondaryActionButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Style Selector="^:pointerover">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceHover}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeStrong}" />
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Background" Value="{StaticResource Brush.SurfacePressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeStrong}" />
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}" />
      </Style>
    </ControlTheme>

    <ControlTheme x:Key="DangerActionButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="{StaticResource Brush.ErrorSurface}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Error}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Style Selector="^:pointerover">
        <Setter Property="Background" Value="{StaticResource Brush.ErrorSurfaceHover}" />
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Background" Value="{StaticResource Brush.ErrorSurfacePressed}" />
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
      </Style>
    </ControlTheme>

    <ControlTheme x:Key="SubtleActionButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
      <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{StaticResource Radius.Small}" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinHeight" Value="40" />
      <Style Selector="^:pointerover">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceHover}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeStrong}" />
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Background" Value="{StaticResource Brush.SurfacePressed}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeStrong}" />
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}" />
      </Style>
    </ControlTheme>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource Brush.Background}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
  </Style>

  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="{StaticResource Font.PageTitle}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="{StaticResource Font.SectionTitle}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
  </Style>

  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="{StaticResource Font.Caption}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
  </Style>

  <Style Selector="TextBlock.secondary">
    <Setter Property="FontSize" Value="{StaticResource Font.Body}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
  </Style>

  <Style Selector="TextBlock.meta-label">
    <Setter Property="FontSize" Value="{StaticResource Font.Caption}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
  </Style>

  <Style Selector="TextBlock.meta-value">
    <Setter Property="FontSize" Value="{StaticResource Font.Body}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
  </Style>

  <Style Selector="Border.app-card">
    <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.CardPadding}" />
  </Style>

  <Style Selector="Border.sub-card">
    <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Border.badge">
    <Setter Property="Background" Value="#143047" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="12,6" />
  </Style>

  <Style Selector="Border.info-strip">
    <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="14,12" />
  </Style>

  <Style Selector="Border.log-row">
    <Setter Property="Background" Value="{StaticResource Brush.SurfaceMuted}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.StrokeSubtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
    <Setter Property="Padding" Value="14,12" />
  </Style>

  <Style Selector="TextBox.settings-input">
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
  </Style>

  <Style Selector="Expander.check-group">
    <Setter Property="Margin" Value="{StaticResource Thickness.SectionGap}" />
  </Style>

  <Style Selector="Button.path-row-button">
    <Setter Property="MinWidth" Value="88" />
  </Style>

  <Style Selector="Button.inline-button">
    <Setter Property="MinWidth" Value="96" />
  </Style>

  <Style Selector="ProgressBar.action-progress">
    <Setter Property="MinWidth" Value="168" />
    <Setter Property="Height" Value="4" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
  </Style>

  <Style Selector="ui|NavigationView">
    <Setter Property="Background" Value="{StaticResource Brush.Background}" />
    <Setter Property="CompactModeThresholdWidth" Value="960" />
    <Setter Property="ExpandedModeThresholdWidth" Value="1280" />
    <Setter Property="OpenPaneLength" Value="248" />
    <Setter Property="IsPaneToggleButtonVisible" Value="True" />
  </Style>

  <Style Selector="ui|NavigationViewItem">
    <Setter Property="Margin" Value="0,0,0,4" />
    <Setter Property="MinHeight" Value="44" />
    <Setter Property="Padding" Value="14,10" />
  </Style>
</Styles>
