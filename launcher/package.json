{
  "name": "@rayleabot/launcher",
  "version": "0.1.0",
  "private": true,
  "description": "RayleaBot Electron desktop launcher",
  "author": "RayleaBot",
  "main": "dist/main/main/index.js",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "node scripts/dev.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && vue-tsc -p tsconfig.renderer.json --noEmit",
    "build:app": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "build": "pnpm run clean && pnpm run build:app && electron-builder --dir"
  },
  "dependencies": {
    "vue": "3.5.31"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "concurrently": "9.2.1",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "jsdom": "29.0.1",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2",
    "vue-tsc": "3.2.6",
    "wait-on": "9.0.4"
  },
  "build": {
    "appId": "local.rayleabot.launcher",
    "productName": "RayleaLauncher",
    "asar": true,
    "directories": {
      "output": "dist/package"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main/index.js"
    },
    "win": {
      "target": [
        "dir"
      ],
      "signAndEditExecutable": false,
      "executableName": "RayleaLauncher"
    },
    "linux": {
      "target": [
        "dir"
      ],
      "executableName": "RayleaLauncher"
    },
    "mac": {
      "target": [
        "dir"
      ]
    }
  }
}
