{
  "name": "@rayleabot/launcher",
  "version": "0.1.0",
  "private": true,
  "description": "RayleaBot Electron desktop launcher",
  "author": "RayleaBot",
  "main": "dist/main/main/index.js",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.32.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "node scripts/dev.mjs",
    "generate:types": "openapi-typescript ../contracts/web-api.openapi.yaml -o src/shared/web-api.generated.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build:app": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "build": "pnpm run clean && pnpm run build:app && node scripts/build-package.mjs"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.316",
    "@fluentui/react-message-bar": "^9.6.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "7.7.4",
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "4.1.2",
    "@types/node": "25.5.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "7.7.1",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "jsdom": "29.0.1",
    "openapi-typescript": "7.8.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2",
    "wait-on": "9.0.4"
  },
  "build": {
    "appId": "local.rayleabot.launcher",
    "productName": "RayleaLauncher",
    "asar": true,
    "directories": {
      "output": "dist/package"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main/index.js"
    },
    "win": {
      "executableName": "RayleaLauncher",
      "target": [
        "dir"
      ],
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        "dir"
      ],
      "executableName": "RayleaLauncher"
    },
    "mac": {
      "target": [
        "dir"
      ]
    }
  }
}
