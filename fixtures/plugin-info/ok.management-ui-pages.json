{
  "contract": "contracts/plugin-info.schema.json",
  "case": "ok",
  "description": "A plugin may declare multiple package-local management page entries.",
  "input": {
    "id": "example-config-panel",
    "name": "Example Config Panel",
    "version": "0.1.0",
    "manifest_version": "1",
    "plugin_protocol_version": "1",
    "type": "managed_runtime",
    "runtime": "python",
    "entry": "main.py",
    "license": "MIT",
    "description": "Python example plugin demonstrating config.read and config.write.",
    "author": "raylea",
    "role": "example",
    "management_ui": {
      "entry": "web/index.html",
      "label": "配置页面",
      "pages": [
        {
          "id": "config",
          "label": "配置页面",
          "entry": "web/index.html"
        },
        {
          "id": "secrets",
          "label": "密钥设置",
          "entry": "web/secrets.html"
        }
      ]
    },
    "capabilities": [
      "event.subscribe",
      "config.read",
      "config.write"
    ],
    "permissions": {
      "required": [
        "config.read",
        "config.write"
      ],
      "optional": []
    },
    "default_config": {
      "default_city": "北京",
      "unit": "celsius"
    }
  },
  "expect": {
    "valid": true
  }
}
