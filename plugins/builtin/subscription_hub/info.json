{
  "id": "raylea.subscription-hub",
  "name": "订阅中心",
  "version": "0.1.0",
  "manifest_version": "1",
  "plugin_protocol_version": "1",
  "type": "managed_runtime",
  "runtime": "python",
  "entry": "main.py",
  "license": "MIT",
  "description": "订阅平台内容并推送更新",
  "author": "raylea",
  "role": "builtin",
  "management_ui": {
    "entry": "web/index.html",
    "label": "订阅设置"
  },
  "render_templates": [
    {
      "path": "templates/bilibili-update"
    }
  ],
  "capabilities": [
    "event.subscribe",
    "message.send",
    "render.image",
    "storage.kv",
    "config.read",
    "config.write",
    "logger.write",
    "http.request",
    "scheduler.create",
    "secret.read"
  ],
  "permissions": {
    "required": [
      "message.send",
      "render.image",
      "storage.kv",
      "config.read",
      "config.write",
      "logger.write",
      "http.request",
      "scheduler.create",
      "secret.read"
    ],
    "optional": [],
    "scopes": {
      "http_hosts": [
        "api.bilibili.com",
        "api.live.bilibili.com"
      ]
    }
  },
  "commands": [
    {
      "name": "订阅状态",
      "description": "查看订阅中心状态",
      "usage": "/订阅状态",
      "permission": "everyone"
    },
    {
      "name": "订阅b站推送",
      "description": "订阅当前群聊或私聊的 Bilibili 更新推送",
      "usage": "/订阅b站推送 [直播|视频|图文|文章|转发] <uid>",
      "permission": "super_admin"
    },
    {
      "name": "取消b站推送",
      "description": "取消当前群聊或私聊的 Bilibili 更新推送",
      "usage": "/取消b站推送 [直播|视频|图文|文章|转发] <uid>",
      "permission": "super_admin"
    },
    {
      "name": "订阅列表",
      "description": "查看当前群聊或私聊的订阅列表",
      "usage": "/订阅列表",
      "permission": "everyone"
    },
    {
      "name": "b站订阅列表",
      "description": "查看当前群聊或私聊的 Bilibili 订阅列表",
      "usage": "/b站订阅列表",
      "permission": "everyone"
    },
    {
      "name": "全部订阅列表",
      "description": "查看所有群聊和私聊的订阅列表",
      "usage": "/全部订阅列表",
      "permission": "super_admin"
    },
    {
      "name": "全部b站订阅列表",
      "description": "查看所有群聊和私聊的 Bilibili 订阅列表",
      "usage": "/全部b站订阅列表",
      "permission": "super_admin"
    }
  ],
  "default_config_file": "default_config.json"
}
