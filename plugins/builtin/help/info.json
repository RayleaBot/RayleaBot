{
  "id": "raylea.help",
  "name": "Help",
  "version": "0.1.0",
  "manifest_version": "1",
  "plugin_protocol_version": "1",
  "type": "managed_runtime",
  "runtime": "python",
  "entry": "main.py",
  "license": "MIT",
  "description": "Built-in help command that lists loaded plugins and commands",
  "author": "raylea",
  "capabilities": [
    "plugin.list",
    "render.image"
  ],
  "permissions": {
    "required": [
      "plugin.list",
      "render.image"
    ],
    "optional": []
  },
  "commands": [
    {
      "name": "help",
      "aliases": ["commands"],
      "description": "显示插件菜单或插件指令说明",
      "usage": "/help [插件名或命令名]",
      "permission": "everyone"
    }
  ]
}
