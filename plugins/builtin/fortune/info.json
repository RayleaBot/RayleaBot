{
  "id": "raylea.fortune",
  "name": "运势",
  "version": "0.1.0",
  "manifest_version": "1",
  "plugin_protocol_version": "1",
  "type": "managed_runtime",
  "runtime": "python",
  "entry": "main.py",
  "license": "MIT",
  "description": "每日运势抽取与统计",
  "author": "raylea",
  "role": "builtin",
  "management_ui": {
    "pages": [
      {
        "id": "settings",
        "label": "运势设置",
        "entry": "web/index.html"
      }
    ]
  },
  "capabilities": [
    "event.subscribe",
    "message.send",
    "render.image",
    "storage.kv",
    "config.read",
    "config.write",
    "logger.write"
  ],
  "dynamic_commands": [
    {
      "id": "fortune",
      "settings_key": "trigger_commands",
      "description": "查看今日运势",
      "permission": "everyone"
    },
    {
      "id": "fortune_stats",
      "settings_key": "stats_trigger_commands",
      "description": "查看运势统计",
      "permission": "everyone"
    }
  ],
  "default_config_file": "fortunes.json"
}
