{
  "id": "raylea.fortune",
  "name": "运势",
  "version": "0.1.0",
  "manifest_version": "1",
  "plugin_protocol_version": "1",
  "type": "managed_runtime",
  "runtime": "python",
  "entry": "main.py",
  "license": "MIT",
  "description": "每日运势抽取与统计",
  "author": "raylea",
  "role": "builtin",
  "management_ui": {
    "entry": "web/index.html",
    "label": "运势设置"
  },
  "capabilities": [
    "event.subscribe",
    "message.send",
    "render.image",
    "storage.kv",
    "config.read",
    "config.write",
    "logger.write"
  ],
  "permissions": {
    "required": [
      "message.send",
      "render.image",
      "storage.kv",
      "config.read",
      "config.write",
      "logger.write"
    ],
    "optional": []
  },
  "dynamic_commands": [
    {
      "id": "fortune",
      "settings_key": "trigger_commands",
      "description": "查看今日运势",
      "permission": "everyone"
    }
  ],
  "default_config": {
    "good_actions": [
      "整理计划",
      "主动沟通",
      "早睡早起",
      "处理积压事项",
      "学习新知识",
      "备份资料"
    ],
    "bad_actions": [
      "拖延决定",
      "冲动消费",
      "熬夜",
      "重复争辩",
      "临时改约",
      "忽略细节"
    ]
  },
  "default_config_file": "fortunes.json"
}
