{
  "id": "example-render-card",
  "name": "Example Render Card",
  "version": "0.1.0",
  "manifest_version": "1",
  "plugin_protocol_version": "1",
  "type": "managed_runtime",
  "runtime": "python",
  "entry": "main.py",
  "license": "MIT",
  "description": "Python example plugin demonstrating render.image.",
  "author": "raylea",
  "role": "example",
  "capabilities": [
    "event.subscribe",
    "message.send",
    "render.image"
  ],
  "permissions": {
    "required": [
      "message.send",
      "render.image"
    ],
    "optional": []
  },
  "render_templates": [
    {
      "path": "templates/card"
    }
  ],
  "commands": [
    {
      "name": "render_card",
      "description": "Render a simple help card image.",
      "usage": "/render_card"
    }
  ]
}
