{
  "name": "rayleabot-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "generate:openapi-types": "openapi-typescript ../contracts/web-api.openapi.yaml -o src/types/generated.ts",
    "generate:ws-types": "node scripts/generate-websocket-types.mjs",
    "generate:types": "pnpm run generate:openapi-types && pnpm run generate:ws-types"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "picomatch": "4.0.4"
    }
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@vueuse/motion": "^3.0.3",
    "ant-design-vue": "4.2.6",
    "pinia": "3.0.4",
    "vue": "3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "24.5.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-v8": "4.1.5",
    "@vue/test-utils": "2.4.6",
    "jsdom": "26.1.0",
    "openapi-typescript": "7.8.0",
    "sass": "1.93.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.2",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue-tsc": "3.0.5",
    "ws": "8.18.3",
    "yaml": "2.8.1"
  }
}
