{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "status"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "user": {
      "type": "object",
      "properties": {
        "avatar_url": {
          "type": "string"
        },
        "nickname": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "id": {
          "type": ["string", "number"]
        }
      },
      "additionalProperties": true
    },
    "group": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "permission": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["super_admin", "owner", "admin", "member"]
        }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": ["string", "number"]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
