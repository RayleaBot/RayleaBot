{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string"
    },
    "render_footer": {
      "type": "string"
    },
    "command_prefixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trigger_examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "user": {
      "type": "object",
      "properties": {
        "avatar_url": {
          "type": "string"
        },
        "nickname": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "id": {
          "type": ["string", "number"]
        }
      },
      "additionalProperties": true
    },
    "group": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "permission": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["super_admin", "owner", "admin", "member"]
        }
      },
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "usage": {
            "type": "string"
          },
          "usage_args": {
            "type": "string"
          },
          "command_prefixes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "permission": {
            "type": "string",
            "enum": ["everyone", "group_admin", "super_admin"]
          },
          "permission_label": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "items"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "description"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "usage": {
                  "type": "string"
                },
                "usage_args": {
                  "type": "string"
                },
                "command_prefixes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "permission": {
                  "type": "string",
                  "enum": ["everyone", "group_admin", "super_admin"]
                },
                "permission_label": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
