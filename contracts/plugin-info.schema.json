{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rayleabot.local/contracts/plugin-info.schema.json",
  "title": "RayleaBot Plugin Info",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "manifest_version",
    "plugin_protocol_version",
    "type",
    "entry",
    "runtime",
    "license"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "manifest_version": { "type": "string", "const": "1" },
    "plugin_protocol_version": { "type": "string", "const": "1" },
    "sdk_min_version": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["managed_runtime", "binary", "dev_source"]
    },
    "entry": { "type": "string", "minLength": 1 },
    "runtime": {
      "type": "string",
      "enum": ["python", "nodejs", "binary"]
    },
    "runtime_version": { "type": "string" },
    "data_schema_version": { "type": "string" },
    "license": { "type": "string", "minLength": 1 },
    "min_core_version": { "type": "string" },
    "platforms": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "role": {
      "type": "string",
      "enum": ["builtin", "user", "example", "dev"]
    },
    "icon": { "type": "string" },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "aliases": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "description": { "type": "string" },
          "usage": { "type": "string" },
          "permission": {
            "type": "string",
            "enum": ["super_admin", "group_admin", "everyone"]
          }
        }
      }
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "scopes": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          },
          "properties": {
            "http_hosts": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "storage": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "python": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nodejs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "require_install_scripts": { "type": "boolean" },
    "repo": { "type": "string", "format": "uri" },
    "homepage": { "type": "string", "format": "uri" },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "screenshots": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "system_dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "$comment": "Phase 0 skeleton. Any future manifest field additions must be added here first, not only in Markdown or implementation."
}
