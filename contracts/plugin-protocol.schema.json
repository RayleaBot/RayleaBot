{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rayleabot.local/contracts/plugin-protocol.schema.json",
  "title": "RayleaBot Plugin JSONL Protocol",
  "description": "Fixture-ready schema for the minimum platform-runtime JSONL protocol. This contract freezes startup, startup progress, rich message.send/message.reply payloads with a shared outbound segment model, legacy message.send_image compatibility, event dispatch, result, error, ping/pong keepalive, and shutdown semantics.",
  "oneOf": [
    {
      "$ref": "#/$defs/init"
    },
    {
      "$ref": "#/$defs/init_progress"
    },
    {
      "$ref": "#/$defs/init_ack"
    },
    {
      "$ref": "#/$defs/event"
    },
    {
      "$ref": "#/$defs/action"
    },
    {
      "$ref": "#/$defs/result"
    },
    {
      "$ref": "#/$defs/error"
    },
    {
      "$ref": "#/$defs/ping"
    },
    {
      "$ref": "#/$defs/pong"
    },
    {
      "$ref": "#/$defs/shutdown"
    }
  ],
  "$defs": {
    "common": {
      "type": "object",
      "required": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id"
      ],
      "properties": {
        "protocol_version": {
          "type": "string",
          "const": "1"
        },
        "type": {
          "type": "string"
        },
        "timestamp": {
          "type": "integer",
          "minimum": 0
        },
        "plugin_id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,62}[a-z0-9])?$"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "init": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "bot"
          ],
          "properties": {
            "type": {
              "const": "init"
            },
            "bot": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "nickname": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z]+\\.[a-z_]+$"
              },
              "uniqueItems": true
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "init_progress": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "summary"
          ],
          "properties": {
            "type": {
              "const": "init_progress"
            },
            "summary": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "init_ack": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "status"
          ],
          "properties": {
            "type": {
              "const": "init_ack"
            },
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "error"
              ]
            },
            "subscriptions": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "error_message": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "event": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "event"
          ],
          "properties": {
            "type": {
              "const": "event"
            },
            "event": {
              "type": "object",
              "required": [
                "event_id",
                "source_protocol",
                "source_adapter",
                "event_type",
                "timestamp"
              ],
              "properties": {
                "event_id": {
                  "type": "string",
                  "minLength": 1
                },
                "source_protocol": {
                  "type": "string",
                  "minLength": 1
                },
                "source_adapter": {
                  "type": "string",
                  "minLength": 1
                },
                "event_type": {
                  "type": "string",
                  "minLength": 1
                },
                "timestamp": {
                  "type": "integer",
                  "minimum": 0
                },
                "actor": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "nickname": {
                      "type": "string"
                    },
                    "role": {
                      "type": "string"
                    }
                  }
                },
                "target": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "type",
                    "id"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "minLength": 1
                    },
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                },
                "payload": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "command": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "args": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "message_id": {
                      "type": "string",
                      "description": "Protocol-native message identifier, if available."
                    },
                    "sub_type": {
                      "type": "string",
                      "description": "Event sub-type for notice events (e.g., approve, invite, kick, leave)."
                    },
                    "operator_id": {
                      "type": "string",
                      "description": "The user who triggered the notice event, if different from the actor."
                    }
                  }
                },
                "message": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "segments": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "type"
                        ],
                        "properties": {
                          "type": {
                            "type": "string",
                            "minLength": 1,
                            "description": "Segment kind: text, image, at, at_all, face, reply, or implementation-specific types."
                          },
                          "data": {
                            "type": "object",
                            "additionalProperties": true,
                            "description": "Segment-specific data fields."
                          }
                        },
                        "additionalProperties": false
                      }
                    },
                    "plain_text": {
                      "type": "string"
                    }
                  }
                },
                "raw_payload": {
                  "type": "object",
                  "description": "Only present when the plugin manifest declares event.raw_payload and the corresponding high-sensitivity permission has been granted.",
                  "additionalProperties": true
                }
              },
              "unevaluatedProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "outbound_message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segments"
      ],
      "properties": {
        "segments": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/outbound_message_non_reply_segment"
              }
            },
            {
              "type": "array",
              "minItems": 1,
              "prefixItems": [
                {
                  "$ref": "#/$defs/outbound_message_segment_reply"
                }
              ],
              "items": {
                "$ref": "#/$defs/outbound_message_non_reply_segment"
              }
            }
          ]
        }
      }
    },
    "outbound_message_segment": {
      "oneOf": [
        {
          "$ref": "#/$defs/outbound_message_segment_text"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_image"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at_all"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_face"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_reply"
        }
      ]
    },
    "outbound_message_non_reply_segment": {
      "oneOf": [
        {
          "$ref": "#/$defs/outbound_message_segment_text"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_image"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at_all"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_face"
        }
      ]
    },
    "outbound_message_segment_text": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "text"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "outbound_message_segment_image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "image"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            }
          },
          "anyOf": [
            {
              "required": [
                "file"
              ]
            },
            {
              "required": [
                "url"
              ]
            }
          ]
        }
      }
    },
    "outbound_message_segment_at": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "at"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "user_id"
          ],
          "properties": {
            "user_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "outbound_message_segment_at_all": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "at_all"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "maxProperties": 0
        }
      }
    },
    "outbound_message_segment_face": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "face"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "face_id"
          ],
          "properties": {
            "face_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "outbound_message_segment_reply": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "reply"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "message_id"
          ],
          "properties": {
            "message_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "action_message_send_legacy_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_id",
        "text"
      ],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": [
            "group",
            "private"
          ]
        },
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_message_send_rich_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_id",
        "message"
      ],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": [
            "group",
            "private"
          ]
        },
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "$ref": "#/$defs/outbound_message"
        }
      }
    },
    "action_message_reply_legacy_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reply_to_message_id",
        "text"
      ],
      "properties": {
        "reply_to_message_id": {
          "type": "string",
          "minLength": 1,
          "description": "The message_id of the message to quote-reply to, as a string."
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_message_reply_rich_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reply_to_event_id",
        "message"
      ],
      "properties": {
        "reply_to_event_id": {
          "type": "string",
          "minLength": 1
        },
        "fallback_to_send_if_missing": {
          "type": "boolean"
        },
        "message": {
          "$ref": "#/$defs/outbound_message"
        }
      }
    },
    "action": {
      "oneOf": [
        {
          "$ref": "#/$defs/action_message_send"
        },
        {
          "$ref": "#/$defs/action_message_reply"
        },
        {
          "$ref": "#/$defs/action_message_send_image"
        }
      ]
    },
    "action_message_send": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "message.send"
            },
            "data": {
              "oneOf": [
                {
                  "$ref": "#/$defs/action_message_send_legacy_data"
                },
                {
                  "$ref": "#/$defs/action_message_send_rich_data"
                }
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "action_message_reply": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "message.reply"
            },
            "data": {
              "oneOf": [
                {
                  "$ref": "#/$defs/action_message_reply_legacy_data"
                },
                {
                  "$ref": "#/$defs/action_message_reply_rich_data"
                }
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "action_message_send_image": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "message.send_image"
            },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "target_type",
                "target_id",
                "file"
              ],
              "properties": {
                "target_type": {
                  "type": "string",
                  "enum": [
                    "group",
                    "private"
                  ]
                },
                "target_id": {
                  "type": "string",
                  "minLength": 1
                },
                "file": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Legacy compatibility path for image references as file:// local path or base64:// encoded data."
                }
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "result": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "status",
            "data"
          ],
          "properties": {
            "type": {
              "const": "result"
            },
            "status": {
              "type": "string",
              "const": "success"
            },
            "data": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "error": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "code",
            "message"
          ],
          "properties": {
            "type": {
              "const": "error"
            },
            "code": {
              "type": "string",
              "pattern": "^(platform|plugin|permission|adapter)\\.[a-z0-9_]+$"
            },
            "message": {
              "type": "string",
              "minLength": 1
            },
            "details": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "ping": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "ping"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "pong": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "pong"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "shutdown": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "reason"
          ],
          "properties": {
            "type": {
              "const": "shutdown"
            },
            "reason": {
              "type": "string",
              "enum": [
                "stop",
                "restart",
                "reload"
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "x-message-catalog": [
    {
      "type": "init",
      "direction": "platform->plugin",
      "request_id_policy": "required_new_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "bot"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.init-init-ack.yaml"
    },
    {
      "type": "init_progress",
      "direction": "plugin->platform",
      "request_id_policy": "required_same_as_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "summary"
      ],
      "example_ref": "fixtures/plugin-protocol/edge.init-progress-before-ack.yaml"
    },
    {
      "type": "init_ack",
      "direction": "plugin->platform",
      "request_id_policy": "required_same_as_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "status"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.init-init-ack.yaml"
    },
    {
      "type": "event",
      "direction": "platform->plugin",
      "request_id_policy": "required_new_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "event"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.event-result.yaml"
    },
    {
      "type": "action",
      "action_kind": "message.send",
      "direction": "plugin->platform",
      "request_id_policy": "required_new_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "action",
        "data"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.action-message-send-segments.yaml"
    },
    {
      "type": "action",
      "action_kind": "message.reply",
      "direction": "plugin->platform",
      "request_id_policy": "required_new_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "action",
        "data"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.action-message-reply-to-event.yaml"
    },
    {
      "type": "action",
      "action_kind": "message.send_image",
      "direction": "plugin->platform",
      "request_id_policy": "required_new_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "action",
        "data"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.action-message-send-image.yaml"
    },
    {
      "type": "result",
      "direction": "plugin->platform",
      "request_id_policy": "required_same_as_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "status",
        "data"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.event-result.yaml"
    },
    {
      "type": "error",
      "direction": "plugin->platform",
      "request_id_policy": "required_same_as_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "code",
        "message"
      ],
      "example_ref": "fixtures/plugin-protocol/ok.event-error.yaml"
    },
    {
      "type": "shutdown",
      "direction": "platform->plugin",
      "request_id_policy": "required_new_request",
      "required_fields": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id",
        "reason"
      ],
      "example_ref": "fixtures/plugin-protocol/edge.shutdown-with-result.yaml"
    },
    {
