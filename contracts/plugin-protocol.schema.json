{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rayleabot.local/contracts/plugin-protocol.schema.json",
  "title": "RayleaBot Plugin JSONL Protocol",
  "description": "Fixture-ready schema for the minimum platform-runtime JSONL protocol. This contract freezes startup, startup progress, message.send/message.reply payloads with a shared outbound segment model, local logger.write/storage.kv/storage.file/http.request action RPC, event dispatch, result, error, ping/pong keepalive, and shutdown semantics.",
  "oneOf": [
    {
      "$ref": "#/$defs/init"
    },
    {
      "$ref": "#/$defs/init_progress"
    },
    {
      "$ref": "#/$defs/init_ack"
    },
    {
      "$ref": "#/$defs/event"
    },
    {
      "$ref": "#/$defs/action"
    },
    {
      "$ref": "#/$defs/result"
    },
    {
      "$ref": "#/$defs/error"
    },
    {
      "$ref": "#/$defs/ping"
    },
    {
      "$ref": "#/$defs/pong"
    },
    {
      "$ref": "#/$defs/shutdown"
    }
  ],
  "$defs": {
    "common": {
      "type": "object",
      "required": [
        "protocol_version",
        "type",
        "timestamp",
        "plugin_id",
        "request_id"
      ],
      "properties": {
        "protocol_version": {
          "type": "string",
          "const": "1"
        },
        "type": {
          "type": "string"
        },
        "timestamp": {
          "type": "integer",
          "minimum": 0
        },
        "plugin_id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,62}[a-z0-9])?$"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "init": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "bot"
          ],
          "properties": {
            "type": {
              "const": "init"
            },
            "bot": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "nickname": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z]+\\.[a-z_]+$"
              },
              "uniqueItems": true
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "init_progress": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "summary"
          ],
          "properties": {
            "type": {
              "const": "init_progress"
            },
            "summary": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "init_ack": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "status"
          ],
          "properties": {
            "type": {
              "const": "init_ack"
            },
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "error"
              ]
            },
            "subscriptions": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "error_message": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "event": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "event"
          ],
          "properties": {
            "type": {
              "const": "event"
            },
            "event": {
              "type": "object",
              "required": [
                "event_id",
                "source_protocol",
                "source_adapter",
                "event_type",
                "timestamp"
              ],
              "properties": {
                "event_id": {
                  "type": "string",
                  "minLength": 1
                },
                "source_protocol": {
                  "type": "string",
                  "minLength": 1
                },
                "source_adapter": {
                  "type": "string",
                  "minLength": 1
                },
                "event_type": {
                  "type": "string",
                  "minLength": 1
                },
                "timestamp": {
                  "type": "integer",
                  "minimum": 0
                },
                "actor": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "nickname": {
                      "type": "string"
                    },
                    "role": {
                      "type": "string"
                    }
                  }
                },
                "target": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "type",
                    "id"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "minLength": 1
                    },
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                },
                "payload": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "command": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "args": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "message_id": {
                      "type": "string",
                      "description": "Protocol-native message identifier, if available."
                    },
                    "sub_type": {
                      "type": "string",
                      "description": "Event sub-type for notice events (e.g., approve, invite, kick, leave)."
                    },
                    "operator_id": {
                      "type": "string",
                      "description": "The user who triggered the notice event, if different from the actor."
                    }
                  }
                },
                "message": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "segments": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "type"
                        ],
                        "properties": {
                          "type": {
                            "type": "string",
                            "minLength": 1,
                            "description": "Segment kind: text, image, at, at_all, face, reply, or implementation-specific types."
                          },
                          "data": {
                            "type": "object",
                            "additionalProperties": true,
                            "description": "Segment-specific data fields."
                          }
                        },
                        "additionalProperties": false
                      }
                    },
                    "plain_text": {
                      "type": "string"
                    }
                  }
                },
                "raw_payload": {
                  "type": "object",
                  "description": "Only present when the plugin manifest declares event.raw_payload and the corresponding high-sensitivity permission has been granted.",
                  "additionalProperties": true
                }
              },
              "unevaluatedProperties": false
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "outbound_message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segments"
      ],
      "properties": {
        "segments": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/outbound_message_non_reply_segment"
              }
            },
            {
              "type": "array",
              "minItems": 1,
              "prefixItems": [
                {
                  "$ref": "#/$defs/outbound_message_segment_reply"
                }
              ],
              "items": {
                "$ref": "#/$defs/outbound_message_non_reply_segment"
              }
            }
          ]
        }
      }
    },
    "outbound_message_segment": {
      "oneOf": [
        {
          "$ref": "#/$defs/outbound_message_segment_text"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_image"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at_all"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_face"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_reply"
        }
      ]
    },
    "outbound_message_non_reply_segment": {
      "oneOf": [
        {
          "$ref": "#/$defs/outbound_message_segment_text"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_image"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_at_all"
        },
        {
          "$ref": "#/$defs/outbound_message_segment_face"
        }
      ]
    },
    "outbound_message_segment_text": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "text"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "outbound_message_segment_image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "image"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            }
          },
          "anyOf": [
            {
              "required": [
                "file"
              ]
            },
            {
              "required": [
                "url"
              ]
            }
          ]
        }
      }
    },
    "outbound_message_segment_at": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "at"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "user_id"
          ],
          "properties": {
            "user_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "outbound_message_segment_at_all": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "at_all"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "maxProperties": 0
        }
      }
    },
    "outbound_message_segment_face": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "face"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "face_id"
          ],
          "properties": {
            "face_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "outbound_message_segment_reply": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "data"
      ],
      "properties": {
        "type": {
          "const": "reply"
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "message_id"
          ],
          "properties": {
            "message_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "action_message_send_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_id",
        "message"
      ],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": [
            "group",
            "private"
          ]
        },
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "$ref": "#/$defs/outbound_message"
        }
      }
    },
    "action_message_reply_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reply_to_event_id",
        "message"
      ],
      "properties": {
        "reply_to_event_id": {
          "type": "string",
          "minLength": 1
        },
        "fallback_to_send_if_missing": {
          "type": "boolean"
        },
        "message": {
          "$ref": "#/$defs/outbound_message"
        }
      }
    },
    "action": {
      "oneOf": [
        {
          "$ref": "#/$defs/action_message_send"
        },
        {
          "$ref": "#/$defs/action_message_reply"
        },
        {
          "$ref": "#/$defs/action_logger_write"
        },
        {
          "$ref": "#/$defs/action_storage_kv"
        },
        {
          "$ref": "#/$defs/action_storage_file"
        },
        {
          "$ref": "#/$defs/action_http_request"
        }
      ]
    },
    "action_message_send": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "message.send"
            },
            "data": {
              "$ref": "#/$defs/action_message_send_data"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "action_message_reply": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "message.reply"
            },
            "data": {
              "$ref": "#/$defs/action_message_reply_data"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "action_logger_write_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "message"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "action_storage_kv_get_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "key"
      ],
      "properties": {
        "operation": {
          "const": "get"
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_storage_kv_set_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "key",
        "value"
      ],
      "properties": {
        "operation": {
          "const": "set"
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": {}
      }
    },
    "action_storage_kv_delete_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "key"
      ],
      "properties": {
        "operation": {
          "const": "delete"
        },
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_storage_kv_list_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "prefix"
      ],
      "properties": {
        "operation": {
          "const": "list"
        },
        "prefix": {
          "type": "string"
        }
      }
    },
    "action_storage_file_read_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "root",
        "path"
      ],
      "properties": {
        "operation": {
          "const": "read"
        },
        "root": {
          "const": "plugin_data"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_storage_file_write_text_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "root",
        "path",
        "content_text"
      ],
      "properties": {
        "operation": {
          "const": "write"
        },
        "root": {
          "const": "plugin_data"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "content_text": {
          "type": "string"
        }
      }
    },
    "action_storage_file_write_base64_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "root",
        "path",
        "content_base64"
      ],
      "properties": {
        "operation": {
          "const": "write"
        },
        "root": {
          "const": "plugin_data"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "content_base64": {
          "type": "string"
        }
      }
    },
    "action_storage_file_delete_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "root",
        "path"
      ],
      "properties": {
        "operation": {
          "const": "delete"
        },
        "root": {
          "const": "plugin_data"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_storage_file_list_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "root",
        "prefix"
      ],
      "properties": {
        "operation": {
          "const": "list"
        },
        "root": {
          "const": "plugin_data"
        },
        "prefix": {
          "type": "string"
        }
      }
    },
    "action_http_request_no_body_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "url"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "HEAD",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "action_http_request_text_body_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "url",
        "body_text"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "body_text": {
          "type": "string"
        }
      }
    },
    "action_http_request_base64_body_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "url",
        "body_base64"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "body_base64": {
          "type": "string"
        }
      }
    },
    "action_logger_write": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "logger.write"
            },
            "data": {
              "$ref": "#/$defs/action_logger_write_data"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "action_storage_kv": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "storage.kv"
            },
            "data": {
              "oneOf": [
                {
                  "$ref": "#/$defs/action_storage_kv_get_data"
                },
                {
                  "$ref": "#/$defs/action_storage_kv_set_data"
                },
                {
                  "$ref": "#/$defs/action_storage_kv_delete_data"
                },
                {
                  "$ref": "#/$defs/action_storage_kv_list_data"
                }
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "action_storage_file": {
      "allOf": [
        {
          "$ref": "#/$defs/common"
        },
        {
          "type": "object",
          "required": [
            "type",
            "action",
            "data"
          ],
          "properties": {
            "type": {
              "const": "action"
            },
            "action": {
              "type": "string",
              "const": "storage.file"
            },
            "data": {
              "oneOf": [
                {
                  "$ref": "#/$defs/action_storage_file_read_data"
                },
                {
                  "$ref": "#/$defs/action_storage_file_write_text_data"
                },
                {
                  "$ref": "#/$defs/action_storage_file_write_base64_data"
