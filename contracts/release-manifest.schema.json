{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rayleabot.local/contracts/release-manifest.schema.json",
  "title": "RayleaBot Release Manifest",
  "description": "Fixture-ready schema for release_manifest.json and build_info.json. This contract freezes the minimal release JSON metadata surface and the link to the controlled dependency manifest via deps_manifest_sha256.",
  "oneOf": [
    {
      "$ref": "#/$defs/releaseManifest"
    },
    {
      "$ref": "#/$defs/buildInfo"
    }
  ],
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{7,40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "file_name",
        "platform",
        "sha256",
        "size",
        "support_level",
        "deps_manifest_sha256",
        "smoke_profile"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "enum": [
            "windows-x64-full",
            "linux-x64-full",
            "macos-arm64-full",
            "linux-x64-server"
          ]
        },
        "file_name": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "enum": [
            "windows-x64",
            "linux-x64",
            "macos-arm64"
          ]
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "support_level": {
          "type": "string",
          "enum": [
            "first_class",
            "experimental"
          ]
        },
        "deps_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "smoke_profile": {
          "type": "string",
          "enum": [
            "windows_full_smoke",
            "linux_full_smoke",
            "macos_full_smoke",
            "linux_server_smoke"
          ]
        }
      }
    },
    "releaseManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "git_commit",
        "built_at",
        "config_schema_version",
        "db_schema_version",
        "plugin_protocol_version",
        "artifacts",
        "release_notes_ref"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/semver"
        },
        "git_commit": {
          "$ref": "#/$defs/gitCommit"
        },
        "built_at": {
          "type": "string",
          "format": "date-time"
        },
        "config_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "db_schema_version": {
          "type": "string",
          "minLength": 1
        },
        "plugin_protocol_version": {
          "type": "string",
          "minLength": 1
        },
        "onebot_matrix": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "transport_matrix_version",
            "compatibility_matrix_version",
            "provider_extension_matrix_version"
          ],
          "properties": {
            "transport_matrix_version": {
              "type": "string",
              "minLength": 1
            },
            "compatibility_matrix_version": {
              "type": "string",
              "minLength": 1
            },
            "provider_extension_matrix_version": {
              "type": "string",
              "minLength": 1
            }
          },
          "description": "Optional validated OneBot11 matrix versions published when the release workflow provides them."
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          },
          "minItems": 1
        },
        "release_notes_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "buildInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "git_commit",
        "artifact_id",
        "built_at"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/semver"
        },
        "git_commit": {
          "$ref": "#/$defs/gitCommit"
        },
        "artifact_id": {
          "type": "string",
          "enum": [
            "windows-x64-full",
            "linux-x64-full",
            "macos-arm64-full",
            "linux-x64-server"
          ]
        },
        "built_at": {
          "type": "string",
          "format": "date-time"
        },
        "release_notes_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Optional release page reference copied from release_manifest.json so packaged builds can open the authoritative release page without querying the Web API."
        },
        "release_manifest_sha256": {
          "$ref": "#/$defs/sha256",
          "description": "Optional digest of the published release_manifest.json. Release packaging keeps this field optional so the package archive checksum remains a stable checksum of the final uploaded bytes."
        },
        "onebot_matrix": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "transport_matrix_version",
            "compatibility_matrix_version",
            "provider_extension_matrix_version"
          ],
          "properties": {
            "transport_matrix_version": {
              "type": "string",
              "minLength": 1
            },
            "compatibility_matrix_version": {
              "type": "string",
              "minLength": 1
            },
            "provider_extension_matrix_version": {
              "type": "string",
              "minLength": 1
            }
          },
          "description": "Optional OneBot11 matrix versions copied from release_manifest.json so packaged builds can expose the validated matrix set."
        }
      }
    }
  },
  "x-fixtures": [
    "fixtures/release-manifest/ok.release-manifest-minimal.json",
    "fixtures/release-manifest/ok.build-info-minimal.json",
    "fixtures/release-manifest/invalid.artifact-missing-sha256.json",
    "fixtures/release-manifest/edge.multi-artifact-official-matrix.json"
  ],
  "$comment": "The release manifest stays focused on artifact metadata and the controlled dependency manifest link. The managed runtime inventory remains in .deps/manifest.json. SHA256SUMS.txt stays on the release-tool verification boundary rather than entering this JSON schema."
}
