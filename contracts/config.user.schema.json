{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rayleabot.local/contracts/config.user.schema.json",
  "title": "RayleaBot User Config",
  "description": "Fixture-ready schema for config/user.yaml. This file is the only formal source for the planning-aligned platform configuration shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "server",
    "onebot",
    "database",
    "command",
    "builtin_features",
    "admin",
    "permission",
    "render",
    "scheduler",
    "runtime",
    "storage",
    "data",
    "log",
    "message",
    "user",
    "group",
    "adapter",
    "http",
    "web",
    "backup"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2",
      "description": "Configuration schema version for bootstrap and migration."
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "port"],
      "properties": {
        "host": {
          "type": "string",
          "default": "127.0.0.1"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 8080
        }
      }
    },
    "onebot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "reverse_ws",
        "forward_ws",
        "http_api",
        "webhook"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["standard", "napcat", "luckylillia"],
          "default": "standard"
        },
        "reverse_ws": {
          "$ref": "#/$defs/onebotWsTransport"
        },
        "forward_ws": {
          "$ref": "#/$defs/onebotWsTransport"
        },
        "http_api": {
          "$ref": "#/$defs/onebotHttpTransport"
        },
        "webhook": {
          "$ref": "#/$defs/onebotHttpTransport"
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "path"],
      "properties": {
        "engine": {
          "type": "string",
          "const": "sqlite",
          "default": "sqlite"
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefixes"],
      "properties": {
        "prefixes": {
          "type": "array",
          "default": ["/"],
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "builtin_features": {
      "type": "object",
      "additionalProperties": false,
      "required": ["menu"],
      "properties": {
        "menu": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commands", "prefixes"],
          "properties": {
            "commands": {
              "type": "array",
              "default": ["help", "帮助"],
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "prefixes": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "admin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "super_admins",
        "session_ttl_days",
        "sliding_renewal",
        "max_sessions",
        "login_fail_limit",
        "login_fail_window_seconds"
      ],
      "properties": {
        "super_admins": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "session_ttl_days": {
          "type": "integer",
          "minimum": 1,
          "default": 7
        },
        "sliding_renewal": {
          "type": "boolean",
          "default": true
        },
        "max_sessions": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "login_fail_limit": {
          "type": "integer",
          "minimum": 1,
          "default": 5
        },
        "login_fail_window_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 300
        }
      }
    },
    "permission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_level", "auto_grant_capabilities"],
      "properties": {
        "default_level": {
          "type": "string",
          "enum": ["super_admin", "group_admin", "everyone"],
          "default": "everyone"
        },
        "auto_grant_capabilities": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_count",
        "browser_args",
        "browser_path",
        "timeout_seconds",
        "queue_wait_timeout_seconds",
        "queue_max_length",
        "footer_template"
      ],
      "properties": {
        "worker_count": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "browser_args": {
          "type": "array",
          "default": ["--disable-gpu"],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "browser_path": {
          "type": "string",
          "default": ""
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "queue_wait_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 15
        },
        "queue_max_length": {
          "type": "integer",
          "minimum": 1,
          "default": 32
        },
        "footer_template": {
          "type": "string",
          "default": "Created By RayleaBot {{rayleabot_version}} & Plugin {{plugin_name}} {{plugin_version}}"
        }
      }
    },
    "scheduler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timezone"],
      "properties": {
        "timezone": {
          "type": "string",
          "default": ""
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_init_timeout_seconds",
        "plugin_init_max_total_seconds",
        "plugin_event_timeout_seconds",
        "max_pending_events_per_plugin",
        "max_pending_control_events_per_plugin",
        "nodejs_max_old_space_size_mb",
        "dependency_install_timeout_seconds",
        "max_concurrent_dependency_installs",
        "ipc_pending_actions_max",
        "ipc_action_burst_limit",
        "stderr_rate_limit_bytes_per_second",
        "max_concurrent_tasks_per_plugin",
        "crash_backoff_initial_seconds",
        "crash_backoff_max_seconds",
        "shutdown_grace_seconds",
        "ipc_message_max_bytes"
      ],
      "properties": {
        "plugin_init_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "plugin_init_max_total_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 300
        },
        "plugin_event_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 60
        },
        "max_pending_events_per_plugin": {
          "type": "integer",
          "minimum": 1,
          "default": 16
        },
        "max_pending_control_events_per_plugin": {
          "type": "integer",
          "minimum": 1,
          "default": 4
        },
        "nodejs_max_old_space_size_mb": {
          "type": "integer",
          "minimum": 1,
          "default": 256
        },
        "dependency_install_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 900
        },
        "max_concurrent_dependency_installs": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "ipc_pending_actions_max": {
          "type": "integer",
          "minimum": 1,
          "default": 256
        },
        "ipc_action_burst_limit": {
          "$ref": "#/$defs/rateLimit",
          "default": "100/1s"
        },
        "stderr_rate_limit_bytes_per_second": {
          "type": "integer",
          "minimum": 1,
          "default": 262144
        },
        "max_concurrent_tasks_per_plugin": {
          "type": "integer",
          "minimum": 1,
          "default": 4,
          "description": "Upper bound for one plugin's concurrent event sessions. The runtime applies min(manifest.concurrency, runtime.max_concurrent_tasks_per_plugin) with a floor of 1."
        },
        "crash_backoff_initial_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 2
        },
        "crash_backoff_max_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 60
        },
        "shutdown_grace_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        },
        "ipc_message_max_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 8388608
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kv_value_max_bytes", "kv_total_limit_mb", "file_max_bytes", "plugin_workdir_soft_limit_mb"],
      "properties": {
        "kv_value_max_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 65536
        },
        "kv_total_limit_mb": {
          "type": "integer",
          "minimum": 1,
          "default": 16
        },
        "file_max_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 10485760
        },
        "plugin_workdir_soft_limit_mb": {
          "type": "integer",
          "minimum": 1,
          "default": 256
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_logs_retention_days",
        "event_records_retention_days",
        "download_cache_retention_days"
      ],
      "properties": {
        "audit_logs_retention_days": {
          "type": "integer",
          "minimum": 1,
          "default": 90
        },
        "event_records_retention_days": {
          "type": "integer",
          "minimum": 1,
          "default": 7
        },
        "download_cache_retention_days": {
          "type": "integer",
          "minimum": 1,
          "default": 15
        }
      }
    },
    "log": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "retention_days", "rate_limit_per_plugin"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1,
          "default": 7
        },
        "rate_limit_per_plugin": {
          "$ref": "#/$defs/rateLimit",
          "default": "200/10s"
        }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rate_limit_per_plugin", "rate_limit_per_target", "circuit_breaker_seconds"],
      "properties": {
        "rate_limit_per_plugin": {
          "$ref": "#/$defs/rateLimit",
          "default": "20/10s"
        },
        "rate_limit_per_target": {
          "$ref": "#/$defs/rateLimit",
          "default": "5/5s"
        },
        "circuit_breaker_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        }
      }
    },
    "user": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_rate_limit", "cooldown_reply"],
      "properties": {
        "command_rate_limit": {
          "$ref": "#/$defs/rateLimit",
          "default": "10/60s"
        },
        "cooldown_reply": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_rate_limit"],
      "properties": {
        "command_rate_limit": {
          "$ref": "#/$defs/rateLimit",
          "default": "30/60s"
        }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connect_timeout_seconds",
        "reconnect_initial_seconds",
        "reconnect_multiplier",
        "reconnect_max_seconds",
        "reconnect_jitter_ratio"
      ],
      "properties": {
        "connect_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 15
        },
        "reconnect_initial_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 2
        },
        "reconnect_multiplier": {
          "type": "number",
          "minimum": 1,
          "default": 2
        },
        "reconnect_max_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 120
        },
        "reconnect_jitter_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.2
        }
      }
    },
    "http": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeout_seconds", "max_retries", "allow_private_hosts"],
      "properties": {
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "default": 2
        },
        "allow_private_hosts": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9.-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "web": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exposure_mode", "setup_local_only"],
      "properties": {
        "exposure_mode": {
          "type": "string",
          "enum": ["localhost_only", "lan_enabled", "public_via_reverse_proxy"],
          "default": "localhost_only"
        },
        "setup_local_only": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "backup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_consistency"],
      "properties": {
        "default_consistency": {
          "type": "string",
          "enum": ["offline", "online"],
          "default": "offline"
        }
      }
    }
  },
  "$defs": {
    "onebotWsTransport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "url", "access_token"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "url": {
          "type": "string",
          "default": "",
          "anyOf": [
            {
              "const": ""
            },
            {
              "format": "uri",
              "pattern": "^(ws|wss)://.+$"
            }
          ]
        },
        "access_token": {
          "type": "string",
          "default": ""
        }
      }
    },
    "onebotHttpTransport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "url", "access_token"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "url": {
          "type": "string",
          "default": "",
          "anyOf": [
            {
              "const": ""
            },
            {
              "format": "uri",
              "pattern": "^https?://.+$"
            }
          ]
        },
        "access_token": {
          "type": "string",
          "default": ""
        }
      }
    },
    "rateLimit": {
      "type": "string",
      "pattern": "^[1-9][0-9]*/[1-9][0-9]*(s|m|h)$"
    }
  },
  "x-fixtures": [
    "fixtures/config/ok.minimal.json",
    "fixtures/config/invalid.onebot-url.json",
    "fixtures/config/edge.public-via-reverse-proxy.json",
    "fixtures/config/ok.with-command-and-cooldown.json"
  ],
  "$comment": "The canonical config document follows the planning-aligned section names. Legacy auth/logging/retention/cooldown/runtime.scheduler_timezone/onebot reconnect fields remain migration inputs only."
}
