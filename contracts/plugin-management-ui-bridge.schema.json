{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rayleabot.local/contracts/plugin-management-ui-bridge.schema.json",
  "title": "RayleaBot Plugin Management UI Bridge",
  "description": "Fixture-ready schema for postMessage traffic between the protected Web management host and a plugin-local management iframe.",
  "oneOf": [
    {
      "$ref": "#/$defs/page_ready"
    },
    {
      "$ref": "#/$defs/host_init"
    },
    {
      "$ref": "#/$defs/settings_reload"
    },
    {
      "$ref": "#/$defs/settings_save"
    },
    {
      "$ref": "#/$defs/settings_changed"
    },
    {
      "$ref": "#/$defs/secrets_reload"
    },
    {
      "$ref": "#/$defs/secrets_save"
    },
    {
      "$ref": "#/$defs/secrets_changed"
    },
    {
      "$ref": "#/$defs/scheduler_trigger"
    },
    {
      "$ref": "#/$defs/scheduler_triggered"
    },
    {
      "$ref": "#/$defs/render_template_open"
    },
    {
      "$ref": "#/$defs/protocol_targets_reload"
    },
    {
      "$ref": "#/$defs/protocol_targets_changed"
    },
    {
      "$ref": "#/$defs/protocol_identities_resolve"
    },
    {
      "$ref": "#/$defs/protocol_identities_resolved"
    },
    {
      "$ref": "#/$defs/bilibili_user_resolve"
    },
    {
      "$ref": "#/$defs/bilibili_user_resolved"
    },
    {
      "$ref": "#/$defs/error_message"
    }
  ],
  "$defs": {
    "plugin_management_ui_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "display_state"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "display_state": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "plugin_management_ui_page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "entry"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,62}[a-z0-9])?$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "entry": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/-]+\\.html$"
        }
      }
    },
    "plugin_trust_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "label"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "official",
            "third_party",
            "unverified",
            "development"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "page_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "page.ready"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "host_init": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "management_host"
        },
        "type": {
          "const": "host.init"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "plugin_id",
            "plugin",
            "trust",
            "default_config",
            "settings",
            "title"
          ],
          "properties": {
            "plugin_id": {
              "type": "string",
              "minLength": 1
            },
            "plugin": {
              "$ref": "#/$defs/plugin_management_ui_summary"
            },
            "trust": {
              "$ref": "#/$defs/plugin_trust_summary"
            },
            "default_config": {
              "type": "object",
              "additionalProperties": true
            },
            "settings": {
              "type": "object",
              "additionalProperties": true
            },
            "secrets": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "page": {
              "$ref": "#/$defs/plugin_management_ui_page"
            }
          }
        }
      }
    },
    "settings_reload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "settings.reload"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "settings_save": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "settings.save"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "values"
          ],
          "properties": {
            "values": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "settings_changed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "management_host"
        },
        "type": {
          "const": "settings.changed"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "values",
            "changed_keys"
          ],
          "properties": {
            "values": {
              "type": "object",
              "additionalProperties": true
            },
            "changed_keys": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "secrets_reload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "secrets.reload"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "secrets_save": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "secrets.save"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "values"
          ],
          "properties": {
            "values": {
              "type": "object",
              "propertyNames": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9_.-]{0,126}[a-z0-9])?$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "deleted_keys": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9_.-]{0,126}[a-z0-9])?$"
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "secrets_changed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "management_host"
        },
        "type": {
          "const": "secrets.changed"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "values",
            "changed_keys"
          ],
          "properties": {
            "values": {
              "type": "object",
              "propertyNames": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9_.-]{0,126}[a-z0-9])?$"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "changed_keys": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9](?:[a-z0-9_.-]{0,126}[a-z0-9])?$"
              },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "scheduler_trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "scheduler.trigger"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job_id"
          ],
          "properties": {
            "job_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "scheduler_triggered": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "management_host"
        },
        "type": {
          "const": "scheduler.triggered"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job_id",
            "plugin_id",
            "triggered"
          ],
          "properties": {
            "job_id": {
              "type": "string",
              "minLength": 1
            },
            "plugin_id": {
              "type": "string",
              "minLength": 1
            },
            "triggered": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "render_template_open": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "render_template.open"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "template_id"
          ],
          "properties": {
            "template_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "protocol_target_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "message"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "protocol",
            "groups",
            "private_users",
            "identity"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protocol_group_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_id",
        "target_name"
      ],
      "properties": {
        "target_type": {
          "const": "group"
        },
        "target_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "target_name": {
          "type": "string",
          "minLength": 1
        },
        "avatar_url": {
          "type": "string"
        }
      }
    },
    "protocol_private_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_id",
        "nickname"
      ],
      "properties": {
        "target_type": {
          "const": "private"
        },
        "target_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "nickname": {
          "type": "string",
          "minLength": 1
        },
        "avatar_url": {
          "type": "string"
        }
      }
    },
    "protocol_targets_reload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "protocol.targets.reload"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protocol_targets_changed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "management_host"
        },
        "type": {
          "const": "protocol.targets.changed"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protocol",
            "available",
            "groups",
            "private_users",
            "issues"
          ],
          "properties": {
            "protocol": {
              "const": "onebot11"
            },
            "available": {
              "type": "boolean"
            },
            "groups": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/protocol_group_target"
              }
            },
            "private_users": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/protocol_private_target"
              }
            },
            "issues": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/protocol_target_issue"
              }
            }
          }
        }
      }
    },
    "protocol_identity_request_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_id",
        "user_id"
      ],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": [
            "group",
            "private"
          ]
        },
        "target_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      }
    },
    "protocol_identities_resolve": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "protocol.identities.resolve"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "items"
          ],
          "properties": {
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 100,
              "items": {
                "$ref": "#/$defs/protocol_identity_request_item"
              }
            }
          }
        }
      }
    },
    "protocol_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_type",
        "target_id",
        "user_id",
        "nickname",
        "avatar_url"
      ],
      "properties": {
        "target_type": {
          "type": "string",
          "enum": [
            "group",
            "private"
          ]
        },
        "target_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "user_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "nickname": {
          "type": "string"
        },
        "group_nickname": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "role_label": {
          "type": "string"
        },
        "avatar_url": {
          "type": "string"
        }
      }
    },
    "protocol_identities_resolved": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "management_host"
        },
        "type": {
          "const": "protocol.identities.resolved"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "items",
            "issues"
          ],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/protocol_identity"
              }
            },
            "issues": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/protocol_target_issue"
              }
            }
          }
        }
      }
    },
    "bilibili_user": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uid",
        "name",
        "avatar_url"
      ],
      "properties": {
        "uid": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "avatar_url": {
          "type": "string"
        },
        "fans": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "bilibili_user_resolve": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "plugin_management_ui"
        },
        "type": {
          "const": "bilibili.user.resolve"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "query"
          ],
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "bilibili_user_resolved": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "const": "management_host"
        },
        "type": {
          "const": "bilibili.user.resolved"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "query",
            "exact",
            "candidates"
          ],
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1
            },
            "exact": {
              "type": "boolean"
            },
            "user": {
              "$ref": "#/$defs/bilibili_user"
            },
            "candidates": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/bilibili_user"
              }
            },
            "message": {
              "type": "string"
            }
          }
        }
      }
    },
    "error_message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "source",
        "type",
        "payload"
      ],
      "properties": {
        "version": {
          "const": "1"
        },
        "source": {
          "enum": [
            "management_host",
            "plugin_management_ui"
          ]
        },
        "type": {
          "const": "error"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "message"
          ],
          "properties": {
            "code": {
              "type": "string",
              "minLength": 1
            },
            "message": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  },
  "x-fixtures": [
    "fixtures/plugin-management-ui/ok.bridge-host-init.json",
    "fixtures/plugin-management-ui/ok.bridge-settings-save.json",
    "fixtures/plugin-management-ui/ok.bridge-secrets-save.json",
    "fixtures/plugin-management-ui/ok.bridge-secrets-changed.json",
    "fixtures/plugin-management-ui/ok.bridge-scheduler-trigger.json",
    "fixtures/plugin-management-ui/ok.bridge-scheduler-triggered.json",
    "fixtures/plugin-management-ui/ok.bridge-render-template-open.json",
    "fixtures/plugin-management-ui/ok.bridge-protocol-targets-reload.json",
